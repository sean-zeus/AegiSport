{% doc %}
  @prompt
    三個商品卡片，上面是商品照片及連結，圖片下面是大標題，下面是商品描述內容，響應式，可調整對齊方式，可以調整切換效果, 手機版要有左右滾動式的選擇, 手機版要有左右滾動式的選擇, 手機版的商品卡片，滾動到該商品卡片時，會放大120%, 手機版商品卡片，寬度要滿版，圖片可以設定連結以及錨點, Description要有HTML調整功能
{% enddoc %}
{% assign ai_gen_id = block.id | replace: '_', '' | downcase %}

{% style %}
  .ai-product-cards-{{ ai_gen_id }} {
    display: block;
    width: {{ block.settings.desktop_width_percent }}%;
    max-width: 100%;
    padding: 40px 20px;
  }

  .ai-product-cards__container-{{ ai_gen_id }} {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: {{ block.settings.card_spacing }}px;
    justify-items: {{ block.settings.alignment }};
  }

  .ai-product-card-{{ ai_gen_id }} {
    width: 100%;
    max-width: 400px;
    text-align: {{ block.settings.text_alignment }};
    opacity: 0;
    transform: translateY(20px);
    animation: ai-product-card-fade-in-{{ ai_gen_id }} 0.6s ease-out forwards;
  }

  .ai-product-card-{{ ai_gen_id }}:nth-child(1) {
    animation-delay: 0s;
  }

  .ai-product-card-{{ ai_gen_id }}:nth-child(2) {
    animation-delay: 0.2s;
  }

  .ai-product-card-{{ ai_gen_id }}:nth-child(3) {
    animation-delay: 0.4s;
  }

  {% if block.settings.transition_effect == 'fade' %}
    @keyframes ai-product-card-fade-in-{{ ai_gen_id }} {
      to {
        opacity: 1;
        transform: translateY(0);
      }
    }
  {% elsif block.settings.transition_effect == 'slide' %}
    @keyframes ai-product-card-fade-in-{{ ai_gen_id }} {
      to {
        opacity: 1;
        transform: translateX(0);
      }
    }
    .ai-product-card-{{ ai_gen_id }} {
      transform: translateX(-30px);
    }
  {% elsif block.settings.transition_effect == 'scale' %}
    @keyframes ai-product-card-fade-in-{{ ai_gen_id }} {
      to {
        opacity: 1;
        transform: scale(1);
      }
    }
    .ai-product-card-{{ ai_gen_id }} {
      transform: scale(0.9);
    }
  {% endif %}

  .ai-product-card__image-wrapper-{{ ai_gen_id }} {
    position: relative;
    width: 100%;
    margin-bottom: {{ block.settings.image_spacing }}px;
    overflow: hidden;
    border-radius: {{ block.settings.image_border_radius }}px;
    background-color: {{ block.settings.image_background_color }};
  }

  .ai-product-card__image-link-{{ ai_gen_id }} {
    display: block;
    text-decoration: none;
  }

  .ai-product-card__image-{{ ai_gen_id }} {
    width: 100%;
    height: auto;
    display: block;
    transition: transform 0.3s ease;
  }

  .ai-product-card__image-wrapper-{{ ai_gen_id }}:hover .ai-product-card__image-{{ ai_gen_id }} {
    transform: scale(1.05);
  }

  .ai-product-card__image-placeholder-{{ ai_gen_id }} {
    width: 100%;
    aspect-ratio: 1 / 1;
    background-color: #f4f4f4;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .ai-product-card__image-placeholder-{{ ai_gen_id }} svg {
    width: 60%;
    height: 60%;
    opacity: 0.3;
  }

  .ai-product-card__title-{{ ai_gen_id }} {
    font-size: {{ block.settings.title_size }}px;
    font-weight: 600;
    color: {{ block.settings.title_color }};
    margin: 0 0 {{ block.settings.title_spacing }}px;
    line-height: 1.3;
  }

  .ai-product-card__description-{{ ai_gen_id }} {
    font-size: {{ block.settings.description_size }}px;
    color: {{ block.settings.description_color }};
    line-height: 1.6;
    margin: 0;
  }

  .ai-product-card__description-{{ ai_gen_id }} p {
    margin: 0 0 10px;
  }

  .ai-product-card__description-{{ ai_gen_id }} p:last-child {
    margin-bottom: 0;
  }

  .ai-product-card__description-{{ ai_gen_id }} ul,
  .ai-product-card__description-{{ ai_gen_id }} ol {
    margin: 0 0 10px;
    padding-left: 20px;
  }

  .ai-product-card__description-{{ ai_gen_id }} strong {
    font-weight: 600;
  }

  .ai-product-card__description-{{ ai_gen_id }} em {
    font-style: italic;
  }

  @media screen and (max-width: 989px) {
    .ai-product-cards__container-{{ ai_gen_id }} {
      grid-template-columns: repeat(2, 1fr);
    }
  }

  @media screen and (max-width: 749px) {
    .ai-product-cards-{{ ai_gen_id }} {
      padding: 60px 0;
      overflow: hidden;
    }

    .ai-product-cards__container-{{ ai_gen_id }} {
      display: flex;
      overflow-x: auto;
      overflow-y: hidden;
      scroll-snap-type: x mandatory;
      -webkit-overflow-scrolling: touch;
      gap: {{ block.settings.card_spacing }}px;
      padding: 0 20px;
      scrollbar-width: none;
    }

    .ai-product-cards__container-{{ ai_gen_id }}::-webkit-scrollbar {
      display: none;
    }

    .ai-product-card-{{ ai_gen_id }} {
      flex: 0 0 100%;
      max-width: 100%;
      scroll-snap-align: center;
      transition: transform 0.3s ease;
      transform: scale(0.85);
    }

    .ai-product-card-{{ ai_gen_id }}.ai-card-active-{{ ai_gen_id }} {
      transform: scale(1.2);
    }

    .ai-product-card__title-{{ ai_gen_id }} {
      font-size: {{ block.settings.title_size | times: 0.9 }}px;
    }

    .ai-product-card__description-{{ ai_gen_id }} {
      font-size: {{ block.settings.description_size | times: 0.9 }}px;
    }
  }
{% endstyle %}

<product-cards-{{ ai_gen_id }} class="ai-product-cards-{{ ai_gen_id }}" {{ block.shopify_attributes }}>
  <div class="ai-product-cards__container-{{ ai_gen_id }}">
    {% for i in (1..3) %}
      {% liquid
        assign product_key = 'product_' | append: i
        assign title_key = 'title_' | append: i
        assign description_key = 'description_' | append: i
        assign image_key = 'image_' | append: i
        assign link_key = 'link_' | append: i
        assign product = block.settings[product_key]
        assign title = block.settings[title_key]
        assign description = block.settings[description_key]
        assign custom_image = block.settings[image_key]
        assign custom_link = block.settings[link_key]
      %}

      <div class="ai-product-card-{{ ai_gen_id }}" data-card-index="{{ forloop.index0 }}">
        <div class="ai-product-card__image-wrapper-{{ ai_gen_id }}">
          {% if custom_link != blank %}
            <a href="{{ custom_link }}" class="ai-product-card__image-link-{{ ai_gen_id }}">
              {% if custom_image %}
                <img
                  src="{{ custom_image | image_url: width: 800 }}"
                  alt="{{ custom_image.alt | escape }}"
                  class="ai-product-card__image-{{ ai_gen_id }}"
                  loading="lazy"
                  width="{{ custom_image.width }}"
                  height="{{ custom_image.height }}"
                >
              {% elsif product != blank and product.featured_image %}
                <img
                  src="{{ product.featured_image | image_url: width: 800 }}"
                  alt="{{ product.featured_image.alt | escape }}"
                  class="ai-product-card__image-{{ ai_gen_id }}"
                  loading="lazy"
                  width="{{ product.featured_image.width }}"
                  height="{{ product.featured_image.height }}"
                >
              {% else %}
                <div class="ai-product-card__image-placeholder-{{ ai_gen_id }}">
                  {{ 'product-1' | placeholder_svg_tag }}
                </div>
              {% endif %}
            </a>
          {% else %}
            {% if custom_image %}
              <img
                src="{{ custom_image | image_url: width: 800 }}"
                alt="{{ custom_image.alt | escape }}"
                class="ai-product-card__image-{{ ai_gen_id }}"
                loading="lazy"
                width="{{ custom_image.width }}"
                height="{{ custom_image.height }}"
              >
            {% elsif product != blank and product.featured_image %}
              <a href="{{ product.url }}" class="ai-product-card__image-link-{{ ai_gen_id }}">
                <img
                  src="{{ product.featured_image | image_url: width: 800 }}"
                  alt="{{ product.featured_image.alt | escape }}"
                  class="ai-product-card__image-{{ ai_gen_id }}"
                  loading="lazy"
                  width="{{ product.featured_image.width }}"
                  height="{{ product.featured_image.height }}"
                >
              </a>
            {% else %}
              <div class="ai-product-card__image-placeholder-{{ ai_gen_id }}">
                {{ 'product-1' | placeholder_svg_tag }}
              </div>
            {% endif %}
          {% endif %}
        </div>

        {% if title != blank %}
          <h3 class="ai-product-card__title-{{ ai_gen_id }}">{{ title }}</h3>
        {% elsif product != blank %}
          <h3 class="ai-product-card__title-{{ ai_gen_id }}">{{ product.title }}</h3>
        {% else %}
          <h3 class="ai-product-card__title-{{ ai_gen_id }}">商品標題 {{ i }}</h3>
        {% endif %}

        {% if description != blank %}
          <div class="ai-product-card__description-{{ ai_gen_id }}">{{ description }}</div>
        {% else %}
          <div class="ai-product-card__description-{{ ai_gen_id }}">請選擇商品或輸入描述內容</div>
        {% endif %}
      </div>
    {% endfor %}
  </div>
</product-cards-{{ ai_gen_id }}>

<script>
  (function() {
    class ProductCards{{ ai_gen_id }} extends HTMLElement {
      constructor() {
        super();
        this.container = null;
        this.cards = [];
        this.observer = null;
      }

      connectedCallback() {
        this.container = this.querySelector('.ai-product-cards__container-{{ ai_gen_id }}');
        this.cards = Array.from(this.querySelectorAll('.ai-product-card-{{ ai_gen_id }}'));
        
        this.observeCards();
        this.setupMobileScroll();
      }

      observeCards() {
        if ('IntersectionObserver' in window) {
          this.observer = new IntersectionObserver((entries) => {
            entries.forEach((entry) => {
              if (entry.isIntersecting) {
                entry.target.style.animationPlayState = 'running';
                this.observer.unobserve(entry.target);
              }
            });
          }, {
            threshold: 0.1
          });

          this.cards.forEach((card) => {
            card.style.animationPlayState = 'paused';
            this.observer.observe(card);
          });
        }
      }

      setupMobileScroll() {
        if (window.innerWidth <= 749 && this.container) {
          this.updateActiveCard();
          
          this.container.addEventListener('scroll', () => {
            this.updateActiveCard();
          });
        }
      }

      updateActiveCard() {
        if (!this.container) return;

        const containerRect = this.container.getBoundingClientRect();
        const containerCenter = containerRect.left + containerRect.width / 2;

        let closestCard = null;
        let closestDistance = Infinity;

        this.cards.forEach((card) => {
          const cardRect = card.getBoundingClientRect();
          const cardCenter = cardRect.left + cardRect.width / 2;
          const distance = Math.abs(containerCenter - cardCenter);

          if (distance < closestDistance) {
            closestDistance = distance;
            closestCard = card;
          }
        });

        this.cards.forEach((card) => {
          card.classList.remove('ai-card-active-{{ ai_gen_id }}');
        });

        if (closestCard) {
          closestCard.classList.add('ai-card-active-{{ ai_gen_id }}');
        }
      }

      disconnectedCallback() {
        if (this.observer) {
          this.observer.disconnect();
        }
      }
    }

    customElements.define('product-cards-{{ ai_gen_id }}', ProductCards{{ ai_gen_id }});
  })();
</script>

