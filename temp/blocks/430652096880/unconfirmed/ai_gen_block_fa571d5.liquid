{% doc %}
  @prompt
    響應式圖片文字編輯器，圖片可以變更對齊方式、圖片長寬、比例。文字可以用HTML編輯與對齊, 文字可以用編輯器修改，圖片可以縮小比例, 文字編輯器有大標和內文可以調整，手機版的文字左右滿版，可以調整padding,圖片可以不顯示和顯示
{% enddoc %}
{% assign ai_gen_id = block.id | replace: '_', '' | downcase %}

{% style %}
  .ai-image-text-editor-{{ ai_gen_id }} {
    display: block;
    width: {{ block.settings.desktop_width_percent }}%;
    max-width: 100%;
    background-color: {{ block.settings.background_color }};
    padding: {{ block.settings.section_padding_top }}px {{ block.settings.section_padding_right }}px {{ block.settings.section_padding_bottom }}px {{ block.settings.section_padding_left }}px;
  }

  .ai-image-text-editor__container-{{ ai_gen_id }} {
    display: flex;
    gap: {{ block.settings.content_gap }}px;
    align-items: {{ block.settings.vertical_alignment }};
    {% if block.settings.layout == 'image_left' %}
      flex-direction: row;
    {% elsif block.settings.layout == 'image_right' %}
      flex-direction: row-reverse;
    {% elsif block.settings.layout == 'image_top' %}
      flex-direction: column;
    {% else %}
      flex-direction: column-reverse;
    {% endif %}
  }

  .ai-image-text-editor__image-wrapper-{{ ai_gen_id }} {
    {% if block.settings.layout == 'image_left' or block.settings.layout == 'image_right' %}
      flex: 0 0 {{ block.settings.image_width_percent }}%;
    {% else %}
      width: 100%;
    {% endif %}
  }

  .ai-image-text-editor__image-container-{{ ai_gen_id }} {
    position: relative;
    width: 100%;
    overflow: hidden;
    border-radius: {{ block.settings.image_border_radius }}px;
    {% if block.settings.image_aspect_ratio == 'natural' %}
      aspect-ratio: auto;
    {% elsif block.settings.image_aspect_ratio == 'square' %}
      aspect-ratio: 1 / 1;
    {% elsif block.settings.image_aspect_ratio == 'portrait' %}
      aspect-ratio: 3 / 4;
    {% elsif block.settings.image_aspect_ratio == 'landscape' %}
      aspect-ratio: 4 / 3;
    {% elsif block.settings.image_aspect_ratio == 'wide' %}
      aspect-ratio: 16 / 9;
    {% endif %}
  }

  .ai-image-text-editor__image-{{ ai_gen_id }} {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }

  .ai-image-text-editor__placeholder-{{ ai_gen_id }} {
    width: 100%;
    height: 100%;
    background-color: #f4f4f4;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .ai-image-text-editor__placeholder-{{ ai_gen_id }} svg {
    width: 100%;
    height: 100%;
    max-width: 300px;
    max-height: 300px;
  }

  .ai-image-text-editor__text-wrapper-{{ ai_gen_id }} {
    {% if block.settings.layout == 'image_left' or block.settings.layout == 'image_right' %}
      flex: 1;
    {% else %}
      width: 100%;
    {% endif %}
    text-align: {{ block.settings.text_alignment }};
  }

  .ai-image-text-editor__heading-{{ ai_gen_id }} {
    color: {{ block.settings.heading_color }};
    font-size: {{ block.settings.heading_size }}px;
    margin: 0 0 {{ block.settings.heading_spacing }}px 0;
    line-height: 1.2;
  }

  .ai-image-text-editor__content-{{ ai_gen_id }} {
    color: {{ block.settings.text_color }};
    font-size: {{ block.settings.text_size }}px;
    line-height: 1.6;
  }

  .ai-image-text-editor__content-{{ ai_gen_id }} p {
    margin: 0 0 1em 0;
  }

  .ai-image-text-editor__content-{{ ai_gen_id }} p:last-child {
    margin-bottom: 0;
  }

  @media screen and (max-width: 749px) {
    .ai-image-text-editor-{{ ai_gen_id }} {
      padding: {{ block.settings.mobile_padding_top }}px {{ block.settings.mobile_padding_right }}px {{ block.settings.mobile_padding_bottom }}px {{ block.settings.mobile_padding_left }}px;
    }

    .ai-image-text-editor__container-{{ ai_gen_id }} {
      flex-direction: column;
      gap: {{ block.settings.mobile_content_gap }}px;
    }

    .ai-image-text-editor__image-wrapper-{{ ai_gen_id }} {
      flex: none;
      width: 100%;
      {% if block.settings.hide_image_mobile %}
        display: none;
      {% endif %}
    }

    .ai-image-text-editor__text-wrapper-{{ ai_gen_id }} {
      flex: none;
      width: 100%;
      padding-left: {{ block.settings.mobile_text_padding_horizontal }}px;
      padding-right: {{ block.settings.mobile_text_padding_horizontal }}px;
    }

    .ai-image-text-editor__heading-{{ ai_gen_id }} {
      font-size: {{ block.settings.mobile_heading_size }}px;
    }

    .ai-image-text-editor__content-{{ ai_gen_id }} {
      font-size: {{ block.settings.mobile_text_size }}px;
    }
  }
{% endstyle %}

<div class="ai-image-text-editor-{{ ai_gen_id }}" {{ block.shopify_attributes }}>
  <div class="ai-image-text-editor__container-{{ ai_gen_id }}">
    <div class="ai-image-text-editor__image-wrapper-{{ ai_gen_id }}">
      <div class="ai-image-text-editor__image-container-{{ ai_gen_id }}">
        {% if block.settings.image %}
          <img
            src="{{ block.settings.image | image_url: width: 2000 }}"
            alt="{{ block.settings.image.alt | escape }}"
            loading="lazy"
            width="{{ block.settings.image.width }}"
            height="{{ block.settings.image.height }}"
            class="ai-image-text-editor__image-{{ ai_gen_id }}"
          >
        {% else %}
          <div class="ai-image-text-editor__placeholder-{{ ai_gen_id }}">
            {{ 'image' | placeholder_svg_tag }}
          </div>
        {% endif %}
      </div>
    </div>

    <div class="ai-image-text-editor__text-wrapper-{{ ai_gen_id }}">
      {% if block.settings.heading != blank %}
        <h2 class="ai-image-text-editor__heading-{{ ai_gen_id }}">
          {{ block.settings.heading }}
        </h2>
      {% endif %}

      {% if block.settings.content != blank %}
        <div class="ai-image-text-editor__content-{{ ai_gen_id }}">
          {{ block.settings.content }}
        </div>
      {% endif %}
    </div>
  </div>
</div>

{% schema %}
{
  "name": "響應式圖片文字編輯器",
  "tag": null,
  "settings": [
    {
      "type": "header",
      "content": "版面配置"
    },
    {
      "type": "select",
      "id": "layout",
      "label": "圖片位置",
      "options": [
        {
          "value": "image_left",
          "label": "左側"
        },
        {
          "value": "image_right",
          "label": "右側"
        },
        {
          "value": "image_top",
          "label": "上方"
        },
        {
          "value": "image_bottom",
          "label": "下方"
        }
      ],
      "default": "image_left"
    },
    {
      "type": "select",
      "id": "vertical_alignment",
      "label": "垂直對齊",
      "options": [
        {
          "value": "flex-start",
          "label": "上方"
        },
        {
          "value": "center",
          "label": "中間"
        },
        {
          "value": "flex-end",
          "label": "下方"
        }
      ],
      "default": "center"
    },
    {
      "type": "range",
      "id": "content_gap",
      "label": "內容間距",
      "min": 0,
      "max": 100,
      "step": 5,
      "unit": "px",
      "default": 40
    },
    {
      "type": "range",
      "id": "desktop_width_percent",
      "label": "Desktop width",
      "min": 50,
      "max": 100,
      "step": 5,
      "unit": "%",
      "default": 100
    },
    {
      "type": "color",
      "id": "background_color",
      "label": "背景顏色",
      "default": "#ffffff"
    },
    {
      "type": "header",
      "content": "圖片設定"
    },
    {
      "type": "image_picker",
      "id": "image",
      "label": "圖片"
    },
    {
      "type": "range",
      "id": "image_width_percent",
      "label": "圖片寬度比例",
      "min": 20,
      "max": 80,
      "step": 5,
      "unit": "%",
      "default": 50
    },
    {
      "type": "select",
      "id": "image_aspect_ratio",
      "label": "圖片比例",
      "options": [
        {
          "value": "natural",
          "label": "原始比例"
        },
        {
          "value": "square",
          "label": "正方形 (1:1)"
        },
        {
          "value": "portrait",
          "label": "直式 (3:4)"
        },
        {
          "value": "landscape",
          "label": "橫式 (4:3)"
        },
        {
          "value": "wide",
          "label": "寬螢幕 (16:9)"
        }
      ],
      "default": "natural"
    },
    {
      "type": "range",
      "id": "image_border_radius",
      "label": "圖片圓角",
      "min": 0,
      "max": 50,
      "step": 5,
      "unit": "px",
      "default": 0
    },
    {
      "type": "header",
      "content": "文字內容"
    },
    {
      "type": "inline_richtext",
      "id": "heading",
      "label": "標題",
      "default": "標題文字"
    },
    {
      "type": "richtext",
      "id": "content",
      "label": "內文",
      "default": "<p>在此輸入您的內文內容。您可以使用 HTML 編輯器來格式化文字，包括粗體、斜體、連結等。</p>"
    },
    {
      "type": "select",
      "id": "text_alignment",
      "label": "文字對齊",
      "options": [
        {
          "value": "left",
          "label": "靠左"
        },
        {
          "value": "center",
          "label": "置中"
        },
        {
          "value": "right",
          "label": "靠右"
        }
      ],
      "default": "left"
    },
    {
      "type": "header",
      "content": "標題樣式"
    },
    {
      "type": "range",
      "id": "heading_size",
      "label": "標題大小",
      "min": 16,
      "max": 72,
      "step": 2,
      "unit": "px",
      "default": 32
    },
    {
      "type": "color",
      "id": "heading_color",
      "label": "標題顏色",
      "default": "#222021"
    },
    {
      "type": "range",
      "id": "heading_spacing",
      "label": "標題下方間距",
      "min": 0,
      "max": 50,
      "step": 5,
      "unit": "px",
      "default": 20
    },
    {
      "type": "header",
      "content": "內文樣式"
    },
    {
      "type": "range",
      "id": "text_size",
      "label": "內文大小",
      "min": 12,
      "max": 32,
      "step": 1,
      "unit": "px",
      "default": 16
    },
    {
      "type": "color",
      "id": "text_color",
      "label": "內文顏色",
      "default": "#616161"
    },
    {
      "type": "header",
      "content": "區塊間距"
    },
    {
      "type": "range",
      "id": "section_padding_top",
      "label": "上方間距",
      "min": 0,
      "max": 100,
      "step": 5,
      "unit": "px",
      "default": 40
    },
    {
      "type": "range",
      "id": "section_padding_bottom",
      "label": "下方間距",
      "min": 0,
      "max": 100,
      "step": 5,
      "unit": "px",
      "default": 40
    },
    {
      "type": "range",
      "id": "section_padding_left",
      "label": "左側間距",
      "min": 0,
      "max": 100,
      "step": 5,
      "unit": "px",
      "default": 20
    },
    {
      "type": "range",
      "id": "section_padding_right",
      "label": "右側間距",
      "min": 0,
      "max": 100,
      "step": 5,
      "unit": "px",
      "default": 20
    },
    {
      "type": "header",
      "content": "手機版設定"
    },
    {
      "type": "checkbox",
      "id": "hide_image_mobile",
      "label": "手機版隱藏圖片",
      "default": false
    },
    {
      "type": "range",
      "id": "mobile_content_gap",
      "label": "手機版內容間距",
      "min": 0,
      "max": 60,
      "step": 5,
      "unit": "px",
      "default": 20
    },
    {
      "type": "range",
      "id": "mobile_text_padding_horizontal",
      "label": "手機版文字左右間距",
      "min": 0,
      "max": 50,
      "step": 5,
      "unit": "px",
      "default": 20
    },
    {
      "type": "range",
      "id": "mobile_heading_size",
      "label": "手機版標題大小",
      "min": 16,
      "max": 48,
      "step": 2,
      "unit": "px",
      "default": 24
    },
    {
      "type": "range",
      "id": "mobile_text_size",
      "label": "手機版內文大小",
      "min": 12,
      "max": 24,
      "step": 1,
      "unit": "px",
      "default": 14
    },
    {
      "type": "range",
      "id": "mobile_padding_top",
      "label": "手機版上方間距",
      "min": 0,
      "max": 80,
      "step": 5,
      "unit": "px",
      "default": 30
    },
    {
      "type": "range",
      "id": "mobile_padding_bottom",
      "label": "手機版下方間距",
      "min": 0,
      "max": 80,
      "step": 5,
      "unit": "px",
      "default": 30
    },
    {
      "type": "range",
      "id": "mobile_padding_left",
      "label": "手機版左側間距",
      "min": 0,
      "max": 50,
      "step": 5,
      "unit": "px",
      "default": 0
    },
    {
      "type": "range",
      "id": "mobile_padding_right",
      "label": "手機版右側間距",
      "min": 0,
      "max": 50,
      "step": 5,
      "unit": "px",
      "default": 0
    }
  ],
  "presets": [
    {
      "name": "響應式圖片文字編輯器"
    }
  ]
}
{% endschema %}
