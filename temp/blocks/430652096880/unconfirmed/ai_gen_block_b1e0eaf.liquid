{% doc %}
  @prompt
    響應式圖片文字編輯器，圖片可以變更對齊方式、圖片長寬、比例。文字可以用HTML編輯與對齊
{% enddoc %}
{% assign ai_gen_id = block.id | replace: '_', '' | downcase %}

{% style %}
  .ai-image-text-editor-{{ ai_gen_id }} {
    display: block;
    width: {{ block.settings.desktop_width_percent }}%;
    max-width: 100%;
    background-color: {{ block.settings.background_color }};
    padding: {{ block.settings.section_padding }}px;
  }

  .ai-image-text-editor__container-{{ ai_gen_id }} {
    display: flex;
    gap: {{ block.settings.content_gap }}px;
    align-items: {{ block.settings.vertical_alignment }};
    {% if block.settings.layout == 'image_left' %}
      flex-direction: row;
    {% elsif block.settings.layout == 'image_right' %}
      flex-direction: row-reverse;
    {% elsif block.settings.layout == 'image_top' %}
      flex-direction: column;
    {% else %}
      flex-direction: column-reverse;
    {% endif %}
  }

  .ai-image-text-editor__image-wrapper-{{ ai_gen_id }} {
    {% if block.settings.layout == 'image_left' or block.settings.layout == 'image_right' %}
      flex: 0 0 {{ block.settings.image_width_percent }}%;
    {% else %}
      width: 100%;
    {% endif %}
  }

  .ai-image-text-editor__image-container-{{ ai_gen_id }} {
    position: relative;
    width: 100%;
    overflow: hidden;
    border-radius: {{ block.settings.image_border_radius }}px;
    {% if block.settings.image_aspect_ratio == 'natural' %}
      aspect-ratio: auto;
    {% elsif block.settings.image_aspect_ratio == 'square' %}
      aspect-ratio: 1 / 1;
    {% elsif block.settings.image_aspect_ratio == 'portrait' %}
      aspect-ratio: 3 / 4;
    {% elsif block.settings.image_aspect_ratio == 'landscape' %}
      aspect-ratio: 16 / 9;
    {% elsif block.settings.image_aspect_ratio == 'wide' %}
      aspect-ratio: 21 / 9;
    {% endif %}
  }

  .ai-image-text-editor__image-{{ ai_gen_id }} {
    width: 100%;
    height: 100%;
    object-fit: {{ block.settings.image_fit }};
    display: block;
  }

  .ai-image-text-editor__placeholder-{{ ai_gen_id }} {
    width: 100%;
    height: 100%;
    background-color: #f4f4f4;
    display: flex;
    align-items: center;
    justify-content: center;
    position: relative;
  }

  .ai-image-text-editor__placeholder-{{ ai_gen_id }} svg {
    width: 100%;
    height: 100%;
    max-width: 300px;
    max-height: 300px;
  }

  .ai-image-text-editor__empty-state-{{ ai_gen_id }} {
    position: absolute;
    bottom: 20px;
    left: 50%;
    transform: translateX(-50%);
    padding: 8px 16px;
    font-size: 14px;
    color: #666;
    text-align: center;
    pointer-events: none;
  }

  .ai-image-text-editor__text-wrapper-{{ ai_gen_id }} {
    {% if block.settings.layout == 'image_left' or block.settings.layout == 'image_right' %}
      flex: 1;
    {% else %}
      width: 100%;
    {% endif %}
  }

  .ai-image-text-editor__text-content-{{ ai_gen_id }} {
    color: {{ block.settings.text_color }};
    text-align: {{ block.settings.text_alignment }};
  }

  .ai-image-text-editor__text-content-{{ ai_gen_id }} h1,
  .ai-image-text-editor__text-content-{{ ai_gen_id }} h2,
  .ai-image-text-editor__text-content-{{ ai_gen_id }} h3,
  .ai-image-text-editor__text-content-{{ ai_gen_id }} h4,
  .ai-image-text-editor__text-content-{{ ai_gen_id }} h5,
  .ai-image-text-editor__text-content-{{ ai_gen_id }} h6 {
    margin-top: 0;
    margin-bottom: 16px;
    color: {{ block.settings.heading_color }};
  }

  .ai-image-text-editor__text-content-{{ ai_gen_id }} p {
    margin-top: 0;
    margin-bottom: 16px;
    line-height: 1.6;
  }

  .ai-image-text-editor__text-content-{{ ai_gen_id }} p:last-child {
    margin-bottom: 0;
  }

  .ai-image-text-editor__text-content-{{ ai_gen_id }} a {
    color: {{ block.settings.link_color }};
    text-decoration: underline;
  }

  .ai-image-text-editor__text-content-{{ ai_gen_id }} ul,
  .ai-image-text-editor__text-content-{{ ai_gen_id }} ol {
    margin-bottom: 16px;
    padding-left: 20px;
  }

  .ai-image-text-editor__text-content-{{ ai_gen_id }} img {
    max-width: 100%;
    height: auto;
  }

  @media screen and (max-width: 749px) {
    .ai-image-text-editor__container-{{ ai_gen_id }} {
      flex-direction: column;
      gap: {{ block.settings.mobile_content_gap }}px;
    }

    .ai-image-text-editor__image-wrapper-{{ ai_gen_id }} {
      flex: 0 0 auto;
      width: 100%;
    }

    .ai-image-text-editor__text-wrapper-{{ ai_gen_id }} {
      flex: 0 0 auto;
      width: 100%;
    }

    .ai-image-text-editor__text-content-{{ ai_gen_id }} {
      text-align: {{ block.settings.mobile_text_alignment }};
    }
  }
{% endstyle %}

<div class="ai-image-text-editor-{{ ai_gen_id }}" {{ block.shopify_attributes }}>
  <div class="ai-image-text-editor__container-{{ ai_gen_id }}">
    <div class="ai-image-text-editor__image-wrapper-{{ ai_gen_id }}">
      <div class="ai-image-text-editor__image-container-{{ ai_gen_id }}">
        {% if block.settings.image %}
          <img
            src="{{ block.settings.image | image_url: width: 2000 }}"
            alt="{{ block.settings.image.alt | escape }}"
            loading="lazy"
            width="{{ block.settings.image.width }}"
            height="{{ block.settings.image.height }}"
            class="ai-image-text-editor__image-{{ ai_gen_id }}"
          >
        {% else %}
          <div class="ai-image-text-editor__placeholder-{{ ai_gen_id }}">
            {{ 'image' | placeholder_svg_tag }}
            <div class="ai-image-text-editor__empty-state-{{ ai_gen_id }}">
              請選擇圖片
            </div>
          </div>
        {% endif %}
      </div>
    </div>

    <div class="ai-image-text-editor__text-wrapper-{{ ai_gen_id }}">
      {% if block.settings.text_content != blank %}
        <div class="ai-image-text-editor__text-content-{{ ai_gen_id }}">
          {{ block.settings.text_content }}
        </div>
      {% else %}
        <div class="ai-image-text-editor__text-content-{{ ai_gen_id }}">
          <p>請在設定中編輯文字內容</p>
        </div>
      {% endif %}
    </div>
  </div>
</div>

{% schema %}
{
  "name": "響應式圖片文字編輯器",
  "tag": null,
  "settings": [
    {
      "type": "header",
      "content": "版面配置"
    },
    {
      "type": "select",
      "id": "layout",
      "label": "圖片位置",
      "options": [
        {
          "value": "image_left",
          "label": "圖片在左"
        },
        {
          "value": "image_right",
          "label": "圖片在右"
        },
        {
          "value": "image_top",
          "label": "圖片在上"
        },
        {
          "value": "image_bottom",
          "label": "圖片在下"
        }
      ],
      "default": "image_left"
    },
    {
      "type": "range",
      "id": "desktop_width_percent",
      "label": "桌面版寬度",
      "min": 50,
      "max": 100,
      "step": 5,
      "unit": "%",
      "default": 100
    },
    {
      "type": "range",
      "id": "section_padding",
      "label": "區塊內距",
      "min": 0,
      "max": 100,
      "step": 5,
      "unit": "px",
      "default": 40
    },
    {
      "type": "range",
      "id": "content_gap",
      "label": "內容間距",
      "min": 0,
      "max": 100,
      "step": 5,
      "unit": "px",
      "default": 40
    },
    {
      "type": "range",
      "id": "mobile_content_gap",
      "label": "手機版內容間距",
      "min": 0,
      "max": 60,
      "step": 5,
      "unit": "px",
      "default": 20
    },
    {
      "type": "select",
      "id": "vertical_alignment",
      "label": "垂直對齊",
      "options": [
        {
          "value": "flex-start",
          "label": "頂部"
        },
        {
          "value": "center",
          "label": "置中"
        },
        {
          "value": "flex-end",
          "label": "底部"
        }
      ],
      "default": "center"
    },
    {
      "type": "color",
      "id": "background_color",
      "label": "背景顏色",
      "default": "#ffffff"
    },
    {
      "type": "header",
      "content": "圖片設定"
    },
    {
      "type": "image_picker",
      "id": "image",
      "label": "圖片"
    },
    {
      "type": "range",
      "id": "image_width_percent",
      "label": "圖片寬度比例",
      "info": "僅適用於左右排列",
      "min": 20,
      "max": 80,
      "step": 5,
      "unit": "%",
      "default": 50
    },
    {
      "type": "select",
      "id": "image_aspect_ratio",
      "label": "圖片比例",
      "options": [
        {
          "value": "natural",
          "label": "原始比例"
        },
        {
          "value": "square",
          "label": "正方形 (1:1)"
        },
        {
          "value": "portrait",
          "label": "直式 (3:4)"
        },
        {
          "value": "landscape",
          "label": "橫式 (16:9)"
        },
        {
          "value": "wide",
          "label": "寬螢幕 (21:9)"
        }
      ],
      "default": "natural"
    },
    {
      "type": "select",
      "id": "image_fit",
      "label": "圖片填充方式",
      "options": [
        {
          "value": "cover",
          "label": "覆蓋"
        },
        {
          "value": "contain",
          "label": "包含"
        },
        {
          "value": "fill",
          "label": "填滿"
        }
      ],
      "default": "cover"
    },
    {
      "type": "range",
      "id": "image_border_radius",
      "label": "圖片圓角",
      "min": 0,
      "max": 40,
      "step": 2,
      "unit": "px",
      "default": 0
    },
    {
      "type": "header",
      "content": "文字設定"
    },
    {
      "type": "html",
      "id": "text_content",
      "label": "文字內容 (HTML)",
      "default": "<h2>標題文字</h2><p>這是一段範例文字。您可以使用 HTML 標籤來格式化文字，包括<strong>粗體</strong>、<em>斜體</em>、<a href=\"#\">連結</a>等。</p>"
    },
    {
      "type": "select",
      "id": "text_alignment",
      "label": "文字對齊 (桌面版)",
      "options": [
        {
          "value": "left",
          "label": "靠左"
        },
        {
          "value": "center",
          "label": "置中"
        },
        {
          "value": "right",
          "label": "靠右"
        }
      ],
      "default": "left"
    },
    {
      "type": "select",
      "id": "mobile_text_alignment",
      "label": "文字對齊 (手機版)",
      "options": [
        {
          "value": "left",
          "label": "靠左"
        },
        {
          "value": "center",
          "label": "置中"
        },
        {
          "value": "right",
          "label": "靠右"
        }
      ],
      "default": "left"
    },
    {
      "type": "color",
      "id": "text_color",
      "label": "文字顏色",
      "default": "#616161"
    },
    {
      "type": "color",
      "id": "heading_color",
      "label": "標題顏色",
      "default": "#222021"
    },
    {
      "type": "color",
      "id": "link_color",
      "label": "連結顏色",
      "default": "#aa2424"
    }
  ],
  "presets": [
    {
      "name": "響應式圖片文字編輯器"
    }
  ]
}
{% endschema %}
