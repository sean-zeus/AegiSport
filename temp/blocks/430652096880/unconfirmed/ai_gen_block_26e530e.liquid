{% doc %}
  @prompt
    響應式文字編輯器，大標題和內文分開, 可以編輯padding
{% enddoc %}
{% assign ai_gen_id = block.id | replace: '_', '' | downcase %}

{% style %}
  .ai-text-editor-{{ ai_gen_id }} {
    display: block;
    width: {{ block.settings.desktop_width_percent }}%;
    max-width: 100%;
    padding-top: {{ block.settings.padding_top }}px;
    padding-bottom: {{ block.settings.padding_bottom }}px;
    padding-left: {{ block.settings.padding_left }}px;
    padding-right: {{ block.settings.padding_right }}px;
    background-color: {{ block.settings.background_color }};
    margin: 0 auto;
  }

  .ai-text-editor__container-{{ ai_gen_id }} {
    max-width: {{ block.settings.content_max_width }}px;
    margin: 0 auto;
    text-align: {{ block.settings.text_alignment }};
  }

  .ai-text-editor__heading-{{ ai_gen_id }} {
    color: {{ block.settings.heading_color }};
    font-size: {{ block.settings.heading_size }}px;
    line-height: {{ block.settings.heading_line_height }};
    margin: 0 0 {{ block.settings.spacing_between }}px 0;
    font-weight: {{ block.settings.heading_weight }};
  }

  .ai-text-editor__content-{{ ai_gen_id }} {
    color: {{ block.settings.content_color }};
    font-size: {{ block.settings.content_size }}px;
    line-height: {{ block.settings.content_line_height }};
    margin: 0;
  }

  .ai-text-editor__content-{{ ai_gen_id }} p {
    margin: 0 0 1em 0;
  }

  .ai-text-editor__content-{{ ai_gen_id }} p:last-child {
    margin-bottom: 0;
  }

  .ai-text-editor__content-{{ ai_gen_id }} a {
    color: {{ block.settings.link_color }};
    text-decoration: underline;
  }

  .ai-text-editor__content-{{ ai_gen_id }} a:hover {
    color: {{ block.settings.link_hover_color }};
  }

  @media screen and (max-width: 749px) {
    .ai-text-editor-{{ ai_gen_id }} {
      padding-top: {{ block.settings.padding_top_mobile }}px;
      padding-bottom: {{ block.settings.padding_bottom_mobile }}px;
      padding-left: {{ block.settings.padding_left_mobile }}px;
      padding-right: {{ block.settings.padding_right_mobile }}px;
    }

    .ai-text-editor__heading-{{ ai_gen_id }} {
      font-size: {{ block.settings.heading_size | times: 0.7 }}px;
      margin-bottom: {{ block.settings.spacing_between | times: 0.7 }}px;
    }

    .ai-text-editor__content-{{ ai_gen_id }} {
      font-size: {{ block.settings.content_size | times: 0.9 }}px;
    }
  }

  @media screen and (min-width: 750px) and (max-width: 989px) {
    .ai-text-editor__heading-{{ ai_gen_id }} {
      font-size: {{ block.settings.heading_size | times: 0.85 }}px;
    }

    .ai-text-editor__content-{{ ai_gen_id }} {
      font-size: {{ block.settings.content_size | times: 0.95 }}px;
    }
  }
{% endstyle %}

<div class="ai-text-editor-{{ ai_gen_id }}" {{ block.shopify_attributes }}>
  <div class="ai-text-editor__container-{{ ai_gen_id }}">
    {% if block.settings.heading != blank %}
      <h2 class="ai-text-editor__heading-{{ ai_gen_id }}">
        {{ block.settings.heading }}
      </h2>
    {% endif %}

    {% if block.settings.content != blank %}
      <div class="ai-text-editor__content-{{ ai_gen_id }}">
        {{ block.settings.content }}
      </div>
    {% endif %}
  </div>
</div>

{% schema %}
{
  "name": "響應式文字編輯器",
  "settings": [
    {
      "type": "header",
      "content": "大標題"
    },
    {
      "type": "inline_richtext",
      "id": "heading",
      "label": "標題文字",
      "default": "歡迎來到我們的商店"
    },
    {
      "type": "color",
      "id": "heading_color",
      "label": "顏色",
      "default": "#222021"
    },
    {
      "type": "range",
      "id": "heading_size",
      "label": "字體大小",
      "min": 20,
      "max": 80,
      "step": 2,
      "unit": "px",
      "default": 48
    },
    {
      "type": "select",
      "id": "heading_weight",
      "label": "字體粗細",
      "options": [
        {
          "value": "400",
          "label": "正常"
        },
        {
          "value": "500",
          "label": "中等"
        },
        {
          "value": "600",
          "label": "半粗體"
        },
        {
          "value": "700",
          "label": "粗體"
        }
      ],
      "default": "600"
    },
    {
      "type": "range",
      "id": "heading_line_height",
      "label": "行高",
      "min": 1,
      "max": 2,
      "step": 0.1,
      "default": 1.2
    },
    {
      "type": "header",
      "content": "內文"
    },
    {
      "type": "richtext",
      "id": "content",
      "label": "內文文字",
      "default": "<p>在這裡輸入您的內文內容。您可以使用富文本編輯器來格式化文字，包括粗體、斜體、連結等。</p>"
    },
    {
      "type": "color",
      "id": "content_color",
      "label": "顏色",
      "default": "#616161"
    },
    {
      "type": "range",
      "id": "content_size",
      "label": "字體大小",
      "min": 12,
      "max": 32,
      "step": 1,
      "unit": "px",
      "default": 16
    },
    {
      "type": "range",
      "id": "content_line_height",
      "label": "行高",
      "min": 1,
      "max": 2,
      "step": 0.1,
      "default": 1.6
    },
    {
      "type": "color",
      "id": "link_color",
      "label": "連結顏色",
      "default": "#222021"
    },
    {
      "type": "color",
      "id": "link_hover_color",
      "label": "連結懸停顏色",
      "default": "#aa2424"
    },
    {
      "type": "header",
      "content": "版面配置"
    },
    {
      "type": "range",
      "id": "spacing_between",
      "label": "標題與內文間距",
      "min": 10,
      "max": 60,
      "step": 5,
      "unit": "px",
      "default": 20
    },
    {
      "type": "select",
      "id": "text_alignment",
      "label": "文字對齊",
      "options": [
        {
          "value": "left",
          "label": "靠左"
        },
        {
          "value": "center",
          "label": "置中"
        },
        {
          "value": "right",
          "label": "靠右"
        }
      ],
      "default": "left"
    },
    {
      "type": "range",
      "id": "content_max_width",
      "label": "內容最大寬度",
      "min": 400,
      "max": 1200,
      "step": 50,
      "unit": "px",
      "default": 800
    },
    {
      "type": "range",
      "id": "desktop_width_percent",
      "label": "桌面版寬度",
      "min": 50,
      "max": 100,
      "step": 5,
      "unit": "%",
      "default": 100
    },
    {
      "type": "color",
      "id": "background_color",
      "label": "背景顏色",
      "default": "#ffffff"
    },
    {
      "type": "header",
      "content": "桌面版內距"
    },
    {
      "type": "range",
      "id": "padding_top",
      "label": "上方內距",
      "min": 0,
      "max": 120,
      "step": 5,
      "unit": "px",
      "default": 40
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "label": "下方內距",
      "min": 0,
      "max": 120,
      "step": 5,
      "unit": "px",
      "default": 40
    },
    {
      "type": "range",
      "id": "padding_left",
      "label": "左側內距",
      "min": 0,
      "max": 120,
      "step": 5,
      "unit": "px",
      "default": 40
    },
    {
      "type": "range",
      "id": "padding_right",
      "label": "右側內距",
      "min": 0,
      "max": 120,
      "step": 5,
      "unit": "px",
      "default": 40
    },
    {
      "type": "header",
      "content": "手機版內距"
    },
    {
      "type": "range",
      "id": "padding_top_mobile",
      "label": "上方內距",
      "min": 0,
      "max": 80,
      "step": 5,
      "unit": "px",
      "default": 20
    },
    {
      "type": "range",
      "id": "padding_bottom_mobile",
      "label": "下方內距",
      "min": 0,
      "max": 80,
      "step": 5,
      "unit": "px",
      "default": 20
    },
    {
      "type": "range",
      "id": "padding_left_mobile",
      "label": "左側內距",
      "min": 0,
      "max": 80,
      "step": 5,
      "unit": "px",
      "default": 20
    },
    {
      "type": "range",
      "id": "padding_right_mobile",
      "label": "右側內距",
      "min": 0,
      "max": 80,
      "step": 5,
      "unit": "px",
      "default": 20
    }
  ],
  "presets": [
    {
      "name": "響應式文字編輯器"
    }
  ]
}
{% endschema %}
