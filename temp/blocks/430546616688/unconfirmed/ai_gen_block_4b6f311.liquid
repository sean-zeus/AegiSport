{% doc %}
  @prompt
    可以上傳圖片跟圖片背景的響應式表格, 藍位跟行列可以新增, 行高可以調整高度, 手機版要左右滾動式, 插入圖片的效果可以調整圖片大小
{% enddoc %}
{% assign ai_gen_id = block.id | replace: '_', '' | downcase %}

{% style %}
  .ai-responsive-table-{{ ai_gen_id }} {
    width: {{ block.settings.desktop_width_percent }}%;
    max-width: 100%;
    display: block;
  }

  .ai-responsive-table__wrapper-{{ ai_gen_id }} {
    width: 100%;
    overflow-x: auto;
    -webkit-overflow-scrolling: touch;
    background-color: {{ block.settings.table_background }};
    border-radius: {{ block.settings.border_radius }}px;
  }

  .ai-responsive-table__table-{{ ai_gen_id }} {
    width: 100%;
    border-collapse: collapse;
    min-width: 100%;
  }

  .ai-responsive-table__row-{{ ai_gen_id }} {
    border-bottom: {{ block.settings.border_width }}px solid {{ block.settings.border_color }};
  }

  .ai-responsive-table__row-{{ ai_gen_id }}:last-child {
    border-bottom: none;
  }

  .ai-responsive-table__header-cell-{{ ai_gen_id }} {
    padding: {{ block.settings.cell_padding }}px;
    text-align: {{ block.settings.text_align }};
    background-color: {{ block.settings.header_background }};
    color: {{ block.settings.header_text_color }};
    font-weight: 600;
    border-right: {{ block.settings.border_width }}px solid {{ block.settings.border_color }};
    vertical-align: middle;
  }

  .ai-responsive-table__header-cell-{{ ai_gen_id }}:last-child {
    border-right: none;
  }

  .ai-responsive-table__cell-{{ ai_gen_id }} {
    padding: {{ block.settings.cell_padding }}px;
    text-align: {{ block.settings.text_align }};
    background-color: {{ block.settings.cell_background }};
    color: {{ block.settings.cell_text_color }};
    border-right: {{ block.settings.border_width }}px solid {{ block.settings.border_color }};
    vertical-align: middle;
    height: {{ block.settings.row_height }}px;
  }

  .ai-responsive-table__cell-{{ ai_gen_id }}:last-child {
    border-right: none;
  }

  .ai-responsive-table__cell-image-{{ ai_gen_id }} {
    max-width: {{ block.settings.image_max_width }}px;
    width: 100%;
    height: auto;
    display: block;
    margin: 0 auto;
    object-fit: contain;
  }

  .ai-responsive-table__cell-image-wrapper-{{ ai_gen_id }} {
    width: 100%;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .ai-responsive-table__placeholder-{{ ai_gen_id }} {
    background-color: #f4f4f4;
    width: 60px;
    height: 60px;
    display: flex;
    align-items: center;
    justify-content: center;
    margin: 0 auto;
  }

  .ai-responsive-table__placeholder-{{ ai_gen_id }} svg {
    width: 40px;
    height: 40px;
  }

  @media screen and (max-width: 749px) {
    .ai-responsive-table__wrapper-{{ ai_gen_id }} {
      overflow-x: scroll;
    }

    .ai-responsive-table__table-{{ ai_gen_id }} {
      min-width: 600px;
    }
  }
{% endstyle %}

<div class="ai-responsive-table-{{ ai_gen_id }}" {{ block.shopify_attributes }}>
  <div class="ai-responsive-table__wrapper-{{ ai_gen_id }}">
    <table class="ai-responsive-table__table-{{ ai_gen_id }}">
      {% if block.settings.show_header %}
        <thead>
          <tr class="ai-responsive-table__row-{{ ai_gen_id }}">
            {% for i in (1..block.settings.column_count) %}
              {% liquid
                assign header_key = 'header_' | append: i
                assign header_text = block.settings[header_key]
              %}
              <th class="ai-responsive-table__header-cell-{{ ai_gen_id }}">
                {% if header_text != blank %}
                  {{ header_text }}
                {% else %}
                  欄位 {{ i }}
                {% endif %}
              </th>
            {% endfor %}
          </tr>
        </thead>
      {% endif %}
      <tbody>
        {% for row in (1..block.settings.row_count) %}
          <tr class="ai-responsive-table__row-{{ ai_gen_id }}">
            {% for col in (1..block.settings.column_count) %}
              {% liquid
                assign cell_type_key = 'row_' | append: row | append: '_col_' | append: col | append: '_type'
                assign cell_text_key = 'row_' | append: row | append: '_col_' | append: col | append: '_text'
                assign cell_image_key = 'row_' | append: row | append: '_col_' | append: col | append: '_image'
                assign cell_bg_key = 'row_' | append: row | append: '_col_' | append: col | append: '_bg'
                
                assign cell_type = block.settings[cell_type_key]
                assign cell_text = block.settings[cell_text_key]
                assign cell_image = block.settings[cell_image_key]
                assign cell_bg = block.settings[cell_bg_key]
              %}
              <td 
                class="ai-responsive-table__cell-{{ ai_gen_id }}"
                {% if cell_bg != blank %}style="background-color: {{ cell_bg }};"{% endif %}
              >
                {% if cell_type == 'image' %}
                  <div class="ai-responsive-table__cell-image-wrapper-{{ ai_gen_id }}">
                    {% if cell_image %}
                      <img
                        src="{{ cell_image | image_url: width: 400 }}"
                        alt="{{ cell_image.alt | escape }}"
                        class="ai-responsive-table__cell-image-{{ ai_gen_id }}"
                        loading="lazy"
                        width="{{ block.settings.image_max_width }}"
                        height="auto"
                      >
                    {% else %}
                      <div class="ai-responsive-table__placeholder-{{ ai_gen_id }}">
                        {{ 'image' | placeholder_svg_tag }}
                      </div>
                    {% endif %}
                  </div>
                {% else %}
                  {% if cell_text != blank %}
                    {{ cell_text }}
                  {% else %}
                    -
                  {% endif %}
                {% endif %}
              </td>
            {% endfor %}
          </tr>
        {% endfor %}
      </tbody>
    </table>
  </div>
</div>

