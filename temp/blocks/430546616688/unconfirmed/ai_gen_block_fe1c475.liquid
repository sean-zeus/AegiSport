{% doc %}
  @prompt
    大型粗體文字，以圖片填滿。包含一個可控制背景顏色的設定。
{% enddoc %}
{% assign ai_gen_id = block.id | replace: '_', '' | downcase %}

{% style %}
  .ai-image-filled-text-{{ ai_gen_id }} {
    display: block;
    width: {{ block.settings.desktop_width_percent }}%;
    max-width: 100%;
    padding: 40px 20px;
    background-color: {{ block.settings.background_color }};
    text-align: center;
  }

  .ai-image-filled-text__wrapper-{{ ai_gen_id }} {
    position: relative;
    display: inline-block;
  }

  .ai-image-filled-text__heading-{{ ai_gen_id }} {
    font-size: {{ block.settings.font_size }}px;
    font-weight: 700;
    margin: 0;
    line-height: 1.1;
    background-image: url('{{ block.settings.fill_image | image_url: width: 2000 }}');
    background-size: cover;
    background-position: center;
    background-clip: text;
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    color: transparent;
  }

  .ai-image-filled-text__placeholder-{{ ai_gen_id }} {
    font-size: {{ block.settings.font_size }}px;
    font-weight: 700;
    margin: 0;
    line-height: 1.1;
    color: #cccccc;
  }

  @media screen and (max-width: 749px) {
    .ai-image-filled-text__heading-{{ ai_gen_id }},
    .ai-image-filled-text__placeholder-{{ ai_gen_id }} {
      font-size: calc({{ block.settings.font_size }}px * 0.6);
    }
  }
{% endstyle %}

<div
  class="ai-image-filled-text-{{ ai_gen_id }}"
  {{ block.shopify_attributes }}
>
  <div class="ai-image-filled-text__wrapper-{{ ai_gen_id }}">
    {% if block.settings.fill_image %}
      <h2 class="ai-image-filled-text__heading-{{ ai_gen_id }}">
        {{ block.settings.text }}
      </h2>
    {% else %}
      <h2 class="ai-image-filled-text__placeholder-{{ ai_gen_id }}">
        {{ block.settings.text }}
      </h2>
    {% endif %}
  </div>
</div>

{% schema %}
{
  "name": "圖片填滿文字",
  "settings": [
    {
      "type": "header",
      "content": "文字內容"
    },
    {
      "type": "text",
      "id": "text",
      "label": "文字",
      "default": "大型粗體文字"
    },
    {
      "type": "range",
      "id": "font_size",
      "label": "字體大小",
      "min": 40,
      "max": 200,
      "step": 10,
      "unit": "px",
      "default": 100
    },
    {
      "type": "header",
      "content": "填滿圖片"
    },
    {
      "type": "image_picker",
      "id": "fill_image",
      "label": "填滿圖片"
    },
    {
      "type": "header",
      "content": "樣式"
    },
    {
      "type": "color",
      "id": "background_color",
      "label": "背景顏色",
      "default": "#ffffff"
    },
    {
      "type": "range",
      "id": "desktop_width_percent",
      "label": "桌面寬度",
      "min": 50,
      "max": 100,
      "step": 5,
      "unit": "%",
      "default": 100
    }
  ],
  "presets": [
    {
      "name": "圖片填滿文字"
    }
  ]
}
{% endschema %}
