{% doc %}
  @prompt
    一個可以調整欄位跟行列的響應式表格，有手機版本的模板可以調整，可以調整表格背景色跟高度
{% enddoc %}
{% assign ai_gen_id = block.id | replace: '_', '' | downcase %}

{% style %}
  .ai-responsive-table-{{ ai_gen_id }} {
    width: {{ block.settings.desktop_width_percent }}%;
    max-width: 100%;
    display: block;
  }

  .ai-responsive-table__wrapper-{{ ai_gen_id }} {
    overflow-x: auto;
    -webkit-overflow-scrolling: touch;
  }

  .ai-responsive-table__table-{{ ai_gen_id }} {
    width: 100%;
    border-collapse: collapse;
    background-color: {{ block.settings.table_background_color }};
    border: {{ block.settings.border_width }}px solid {{ block.settings.border_color }};
  }

  .ai-responsive-table__table-{{ ai_gen_id }} th,
  .ai-responsive-table__table-{{ ai_gen_id }} td {
    padding: {{ block.settings.cell_padding }}px;
    text-align: {{ block.settings.text_alignment }};
    border: {{ block.settings.border_width }}px solid {{ block.settings.border_color }};
    height: {{ block.settings.cell_height }}px;
    vertical-align: middle;
  }

  .ai-responsive-table__table-{{ ai_gen_id }} th {
    background-color: {{ block.settings.header_background_color }};
    color: {{ block.settings.header_text_color }};
    font-weight: 600;
    font-size: {{ block.settings.header_font_size }}px;
  }

  .ai-responsive-table__table-{{ ai_gen_id }} td {
    background-color: {{ block.settings.cell_background_color }};
    color: {{ block.settings.cell_text_color }};
    font-size: {{ block.settings.cell_font_size }}px;
  }

  .ai-responsive-table__table-{{ ai_gen_id }} tr:nth-child(even) td {
    {% if block.settings.enable_striped_rows %}
      background-color: {{ block.settings.striped_row_color }};
    {% endif %}
  }

  .ai-responsive-table__table-{{ ai_gen_id }} tr:hover td {
    {% if block.settings.enable_hover_effect %}
      background-color: {{ block.settings.hover_color }};
    {% endif %}
  }

  @media screen and (max-width: 749px) {
    {% if block.settings.mobile_layout == 'stack' %}
      .ai-responsive-table__table-{{ ai_gen_id }} {
        border: 0;
      }

      .ai-responsive-table__table-{{ ai_gen_id }} thead {
        display: none;
      }

      .ai-responsive-table__table-{{ ai_gen_id }} tr {
        display: block;
        margin-bottom: 16px;
        border: {{ block.settings.border_width }}px solid {{ block.settings.border_color }};
      }

      .ai-responsive-table__table-{{ ai_gen_id }} td {
        display: block;
        text-align: right;
        border: none;
        border-bottom: {{ block.settings.border_width }}px solid {{ block.settings.border_color }};
        position: relative;
        padding-left: 50%;
      }

      .ai-responsive-table__table-{{ ai_gen_id }} td:last-child {
        border-bottom: 0;
      }

      .ai-responsive-table__table-{{ ai_gen_id }} td::before {
        content: attr(data-label);
        position: absolute;
        left: {{ block.settings.cell_padding }}px;
        width: 45%;
        padding-right: 10px;
        white-space: nowrap;
        text-align: left;
        font-weight: 600;
        color: {{ block.settings.header_text_color }};
      }
    {% elsif block.settings.mobile_layout == 'scroll' %}
      .ai-responsive-table__wrapper-{{ ai_gen_id }} {
        overflow-x: scroll;
      }

      .ai-responsive-table__table-{{ ai_gen_id }} {
        min-width: 600px;
      }
    {% endif %}
  }
{% endstyle %}

<responsive-table-{{ ai_gen_id }} class="ai-responsive-table-{{ ai_gen_id }}" {{ block.shopify_attributes }}>
  <div class="ai-responsive-table__wrapper-{{ ai_gen_id }}">
    <table class="ai-responsive-table__table-{{ ai_gen_id }}">
      <thead>
        <tr>
          {% for i in (1..block.settings.columns) %}
            {% assign header_key = 'header_' | append: i %}
            <th>{{ block.settings[header_key] }}</th>
          {% endfor %}
        </tr>
      </thead>
      <tbody>
        {% for row in (1..block.settings.rows) %}
          <tr>
            {% for col in (1..block.settings.columns) %}
              {% assign cell_key = 'row_' | append: row | append: '_col_' | append: col %}
              {% assign header_key = 'header_' | append: col %}
              <td data-label="{{ block.settings[header_key] }}">
                {{ block.settings[cell_key] }}
              </td>
            {% endfor %}
          </tr>
        {% endfor %}
      </tbody>
    </table>
  </div>
</responsive-table-{{ ai_gen_id }}>

<script>
  (function() {
    class ResponsiveTable{{ ai_gen_id }} extends HTMLElement {
      constructor() {
        super();
      }

      connectedCallback() {
        this.updateDataLabels();
      }

      updateDataLabels() {
        const headers = this.querySelectorAll('th');
        const rows = this.querySelectorAll('tbody tr');

        rows.forEach(row => {
          const cells = row.querySelectorAll('td');
          cells.forEach((cell, index) => {
            if (headers[index]) {
              cell.setAttribute('data-label', headers[index].textContent);
            }
          });
        });
      }
    }

    customElements.define('responsive-table-{{ ai_gen_id }}', ResponsiveTable{{ ai_gen_id }});
  })();
</script>

