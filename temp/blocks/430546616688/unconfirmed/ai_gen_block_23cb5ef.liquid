{% doc %}
  @prompt
    三個產品卡片，置中對齊，上方顯示產品圖片，下方顯示價格和標題。加入平滑的全息光澤效果與陰影。
{% enddoc %}
{% assign ai_gen_id = block.id | replace: '_', '' | downcase %}

{% style %}
  .ai-holographic-cards-{{ ai_gen_id }} {
    display: block;
    width: {{ block.settings.desktop_width_percent }}%;
    max-width: 100%;
    padding: {{ block.settings.section_padding }}px 0;
  }

  .ai-holographic-cards__container-{{ ai_gen_id }} {
    display: flex;
    justify-content: center;
    align-items: stretch;
    gap: {{ block.settings.card_gap }}px;
    flex-wrap: wrap;
  }

  .ai-holographic-cards__card-{{ ai_gen_id }} {
    flex: 0 1 calc(33.333% - {{ block.settings.card_gap | times: 2 | divided_by: 3 }}px);
    min-width: 250px;
    background: {{ block.settings.card_background }};
    border-radius: {{ block.settings.border_radius }}px;
    padding: {{ block.settings.card_padding }}px;
    position: relative;
    overflow: hidden;
    box-shadow: 0 {{ block.settings.shadow_offset }}px {{ block.settings.shadow_blur }}px rgba(0, 0, 0, {{ block.settings.shadow_opacity }});
    transition: transform 0.3s ease, box-shadow 0.3s ease;
  }

  .ai-holographic-cards__card-{{ ai_gen_id }}:hover {
    transform: translateY(-{{ block.settings.hover_lift }}px);
    box-shadow: 0 {{ block.settings.shadow_offset | plus: 4 }}px {{ block.settings.shadow_blur | plus: 8 }}px rgba(0, 0, 0, {{ block.settings.shadow_opacity | plus: 0.1 }});
  }

  .ai-holographic-cards__card-{{ ai_gen_id }}::before {
    content: '';
    position: absolute;
    top: -50%;
    left: -50%;
    width: 200%;
    height: 200%;
    background: linear-gradient(
      45deg,
      transparent 30%,
      rgba(255, 255, 255, 0.1) 40%,
      rgba(255, 255, 255, 0.3) 50%,
      rgba(255, 255, 255, 0.1) 60%,
      transparent 70%
    );
    background-size: 200% 200%;
    animation: ai-holographic-shine-{{ ai_gen_id }} 3s linear infinite;
    pointer-events: none;
    opacity: {{ block.settings.holographic_intensity }};
  }

  .ai-holographic-cards__card-{{ ai_gen_id }}::after {
    content: '';
    position: absolute;
    top: 0;
    left: 0;
    right: 0;
    bottom: 0;
    background: linear-gradient(
      135deg,
      rgba({{ block.settings.holographic_color_1 | color_extract: 'red' }}, {{ block.settings.holographic_color_1 | color_extract: 'green' }}, {{ block.settings.holographic_color_1 | color_extract: 'blue' }}, 0.2) 0%,
      rgba({{ block.settings.holographic_color_2 | color_extract: 'red' }}, {{ block.settings.holographic_color_2 | color_extract: 'green' }}, {{ block.settings.holographic_color_2 | color_extract: 'blue' }}, 0.2) 25%,
      rgba({{ block.settings.holographic_color_3 | color_extract: 'red' }}, {{ block.settings.holographic_color_3 | color_extract: 'green' }}, {{ block.settings.holographic_color_3 | color_extract: 'blue' }}, 0.2) 50%,
      rgba({{ block.settings.holographic_color_2 | color_extract: 'red' }}, {{ block.settings.holographic_color_2 | color_extract: 'green' }}, {{ block.settings.holographic_color_2 | color_extract: 'blue' }}, 0.2) 75%,
      rgba({{ block.settings.holographic_color_1 | color_extract: 'red' }}, {{ block.settings.holographic_color_1 | color_extract: 'green' }}, {{ block.settings.holographic_color_1 | color_extract: 'blue' }}, 0.2) 100%
    );
    background-size: 400% 400%;
    animation: ai-holographic-gradient-{{ ai_gen_id }} 4s ease infinite;
    pointer-events: none;
    opacity: {{ block.settings.holographic_intensity }};
  }

  @keyframes ai-holographic-shine-{{ ai_gen_id }} {
    0% {
      background-position: 200% 200%;
    }
    100% {
      background-position: -200% -200%;
    }
  }

  @keyframes ai-holographic-gradient-{{ ai_gen_id }} {
    0%, 100% {
      background-position: 0% 50%;
    }
    50% {
      background-position: 100% 50%;
    }
  }

  .ai-holographic-cards__image-wrapper-{{ ai_gen_id }} {
    position: relative;
    width: 100%;
    margin-bottom: {{ block.settings.image_spacing }}px;
    border-radius: {{ block.settings.image_border_radius }}px;
    overflow: hidden;
    background-color: #f4f4f4;
  }

  .ai-holographic-cards__image-{{ ai_gen_id }} {
    width: 100%;
    height: auto;
    display: block;
    aspect-ratio: 1 / 1;
    object-fit: cover;
  }

  .ai-holographic-cards__placeholder-{{ ai_gen_id }} {
    width: 100%;
    aspect-ratio: 1 / 1;
    display: flex;
    align-items: center;
    justify-content: center;
    background-color: #f4f4f4;
  }

  .ai-holographic-cards__placeholder-{{ ai_gen_id }} svg {
    width: 60%;
    height: 60%;
    opacity: 0.3;
  }

  .ai-holographic-cards__content-{{ ai_gen_id }} {
    position: relative;
    z-index: 1;
    text-align: center;
  }

  .ai-holographic-cards__price-{{ ai_gen_id }} {
    font-size: {{ block.settings.price_font_size }}px;
    font-weight: 700;
    color: {{ block.settings.price_color }};
    margin-bottom: {{ block.settings.price_spacing }}px;
    font-family: {{ block.settings.price_font.family }}, {{ block.settings.price_font.fallback_families }};
    font-weight: {{ block.settings.price_font.weight }};
  }

  .ai-holographic-cards__title-{{ ai_gen_id }} {
    font-size: {{ block.settings.title_font_size }}px;
    font-weight: 600;
    color: {{ block.settings.title_color }};
    margin: 0;
    line-height: 1.4;
    font-family: {{ block.settings.title_font.family }}, {{ block.settings.title_font.fallback_families }};
    font-weight: {{ block.settings.title_font.weight }};
  }

  .ai-holographic-cards__link-{{ ai_gen_id }} {
    text-decoration: none;
    color: inherit;
    display: block;
  }

  .ai-holographic-cards__empty-state-{{ ai_gen_id }} {
    text-align: center;
    padding: 20px;
    color: #999;
    font-size: 14px;
  }

  @media screen and (max-width: 768px) {
    .ai-holographic-cards__card-{{ ai_gen_id }} {
      flex: 0 1 100%;
      max-width: 400px;
    }
  }
{% endstyle %}

<holographic-product-cards-{{ ai_gen_id }}
  class="ai-holographic-cards-{{ ai_gen_id }}"
  {{ block.shopify_attributes }}
>
  <div class="ai-holographic-cards__container-{{ ai_gen_id }}">
    {% for i in (1..3) %}
      {% liquid
        assign product_key = 'product_' | append: i
        assign product = block.settings[product_key]
      %}

      <div class="ai-holographic-cards__card-{{ ai_gen_id }}">
        {% if product != blank %}
          <a href="{{ product.url }}" class="ai-holographic-cards__link-{{ ai_gen_id }}">
            <div class="ai-holographic-cards__image-wrapper-{{ ai_gen_id }}">
              {% if product.featured_image %}
                <img
                  src="{{ product.featured_image | image_url: width: 600 }}"
                  alt="{{ product.featured_image.alt | escape }}"
                  class="ai-holographic-cards__image-{{ ai_gen_id }}"
                  loading="lazy"
                  width="600"
                  height="600"
                >
              {% else %}
                <div class="ai-holographic-cards__placeholder-{{ ai_gen_id }}">
                  {{ 'product-1' | placeholder_svg_tag }}
                </div>
              {% endif %}
            </div>

            <div class="ai-holographic-cards__content-{{ ai_gen_id }}">
              <div class="ai-holographic-cards__price-{{ ai_gen_id }}">
                {{ product.price | money }}
              </div>
              <h3 class="ai-holographic-cards__title-{{ ai_gen_id }}">
                {{ product.title }}
              </h3>
            </div>
          </a>
        {% else %}
          <div class="ai-holographic-cards__image-wrapper-{{ ai_gen_id }}">
            <div class="ai-holographic-cards__placeholder-{{ ai_gen_id }}">
              {{ 'product-1' | placeholder_svg_tag }}
            </div>
          </div>
          <div class="ai-holographic-cards__content-{{ ai_gen_id }}">
            <div class="ai-holographic-cards__empty-state-{{ ai_gen_id }}">
              選擇產品 {{ i }}
            </div>
          </div>
        {% endif %}
      </div>
    {% endfor %}
  </div>
</holographic-product-cards-{{ ai_gen_id }}>

<script>
  (function() {
    class HolographicProductCards{{ ai_gen_id }} extends HTMLElement {
      constructor() {
        super();
      }

      connectedCallback() {
        this.cards = this.querySelectorAll('.ai-holographic-cards__card-{{ ai_gen_id }}');
        this.setupHoverEffects();
      }

      setupHoverEffects() {
        this.cards.forEach((card) => {
          card.addEventListener('mousemove', (e) => {
            const rect = card.getBoundingClientRect();
            const x = e.clientX - rect.left;
            const y = e.clientY - rect.top;
            
            const centerX = rect.width / 2;
            const centerY = rect.height / 2;
            
            const rotateX = (y - centerY) / 20;
            const rotateY = (centerX - x) / 20;
            
            card.style.transform = `perspective(1000px) rotateX(${rotateX}deg) rotateY(${rotateY}deg) translateY(-{{ block.settings.hover_lift }}px)`;
          });

          card.addEventListener('mouseleave', () => {
            card.style.transform = '';
          });
        });
      }
    }

    customElements.define('holographic-product-cards-{{ ai_gen_id }}', HolographicProductCards{{ ai_gen_id }});
  })();
</script>

