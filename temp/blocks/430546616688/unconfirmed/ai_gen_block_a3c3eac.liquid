{% doc %}
  @prompt
    一個可以調整欄位跟行列數量的表格。底色可以填入色碼
{% enddoc %}
{% assign ai_gen_id = block.id | replace: '_', '' | downcase %}

{% style %}
  .ai-custom-table-{{ ai_gen_id }} {
    width: {{ block.settings.desktop_width_percent }}%;
    max-width: 100%;
    display: block;
  }

  .ai-custom-table__wrapper-{{ ai_gen_id }} {
    overflow-x: auto;
    border-radius: {{ block.settings.border_radius }}px;
  }

  .ai-custom-table__table-{{ ai_gen_id }} {
    width: 100%;
    border-collapse: collapse;
    background-color: {{ block.settings.table_background }};
    border: {{ block.settings.border_width }}px solid {{ block.settings.border_color }};
  }

  .ai-custom-table__header-cell-{{ ai_gen_id }} {
    padding: {{ block.settings.cell_padding }}px;
    text-align: {{ block.settings.header_alignment }};
    background-color: {{ block.settings.header_background }};
    color: {{ block.settings.header_text_color }};
    font-weight: 600;
    border: {{ block.settings.border_width }}px solid {{ block.settings.border_color }};
    font-size: {{ block.settings.header_font_size }}px;
  }

  .ai-custom-table__cell-{{ ai_gen_id }} {
    padding: {{ block.settings.cell_padding }}px;
    text-align: {{ block.settings.cell_alignment }};
    color: {{ block.settings.cell_text_color }};
    border: {{ block.settings.border_width }}px solid {{ block.settings.border_color }};
    font-size: {{ block.settings.cell_font_size }}px;
  }

  .ai-custom-table__row-{{ ai_gen_id }}:nth-child(even) .ai-custom-table__cell-{{ ai_gen_id }} {
    {% if block.settings.enable_striped %}
      background-color: {{ block.settings.striped_background }};
    {% endif %}
  }

  .ai-custom-table__row-{{ ai_gen_id }}:hover .ai-custom-table__cell-{{ ai_gen_id }} {
    {% if block.settings.enable_hover %}
      background-color: {{ block.settings.hover_background }};
    {% endif %}
  }

  @media screen and (max-width: 749px) {
    .ai-custom-table__header-cell-{{ ai_gen_id }},
    .ai-custom-table__cell-{{ ai_gen_id }} {
      padding: {{ block.settings.cell_padding | times: 0.7 }}px;
      font-size: {{ block.settings.cell_font_size | times: 0.9 }}px;
    }

    .ai-custom-table__header-cell-{{ ai_gen_id }} {
      font-size: {{ block.settings.header_font_size | times: 0.9 }}px;
    }
  }
{% endstyle %}

<custom-table-{{ ai_gen_id }}
  class="ai-custom-table-{{ ai_gen_id }}"
  {{ block.shopify_attributes }}
>
  <div class="ai-custom-table__wrapper-{{ ai_gen_id }}">
    <table class="ai-custom-table__table-{{ ai_gen_id }}">
      <thead>
        <tr>
          {% for i in (1..block.settings.columns) %}
            {% assign header_key = 'header_' | append: i %}
            <th class="ai-custom-table__header-cell-{{ ai_gen_id }}">
              {% if block.settings[header_key] != blank %}
                {{ block.settings[header_key] }}
              {% else %}
                欄位 {{ i }}
              {% endif %}
            </th>
          {% endfor %}
        </tr>
      </thead>
      <tbody>
        {% for row in (1..block.settings.rows) %}
          <tr class="ai-custom-table__row-{{ ai_gen_id }}">
            {% for col in (1..block.settings.columns) %}
              {% assign cell_key = 'row_' | append: row | append: '_col_' | append: col %}
              <td class="ai-custom-table__cell-{{ ai_gen_id }}">
                {% if block.settings[cell_key] != blank %}
                  {{ block.settings[cell_key] }}
                {% else %}
                  -
                {% endif %}
              </td>
            {% endfor %}
          </tr>
        {% endfor %}
      </tbody>
    </table>
  </div>
</custom-table-{{ ai_gen_id }}>

<script>
  (function() {
    class CustomTable{{ ai_gen_id }} extends HTMLElement {
      constructor() {
        super();
      }

      connectedCallback() {
        this.style.display = 'block';
      }
    }

    customElements.define('custom-table-{{ ai_gen_id }}', CustomTable{{ ai_gen_id }});
  })();
</script>

