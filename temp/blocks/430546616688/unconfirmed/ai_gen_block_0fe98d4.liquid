{% doc %}
  @prompt
    可以新增數量的商品卡片，商品圖片的尺寸可以調整比例，圖片的下面是大標題，可以設定連結，最下面是商品描述，滑鼠移動到商品卡片上面會有浮動式笑果，手機版要左右滾動的效果，並且中間的商品卡片比較大，左右的商隱卡片比較小，約70%，並且停明度80%
{% enddoc %}
{% assign ai_gen_id = block.id | replace: '_', '' | downcase %}

{% style %}
  .ai-product-carousel-{{ ai_gen_id }} {
    width: 100%;
    display: block;
    padding: 40px 0;
    background-color: {{ block.settings.background_color }};
  }

  .ai-product-carousel__container-{{ ai_gen_id }} {
    width: {{ block.settings.desktop_width_percent }}%;
    max-width: 100%;
    margin: 0 auto;
  }

  .ai-product-carousel__grid-{{ ai_gen_id }} {
    display: grid;
    grid-template-columns: repeat({{ block.settings.products_per_row }}, 1fr);
    gap: {{ block.settings.grid_gap }}px;
  }

  .ai-product-card-{{ ai_gen_id }} {
    background-color: {{ block.settings.card_background }};
    border-radius: {{ block.settings.card_border_radius }}px;
    overflow: hidden;
    transition: transform 0.3s ease, box-shadow 0.3s ease;
    display: flex;
    flex-direction: column;
  }

  .ai-product-card-{{ ai_gen_id }}:hover {
    transform: translateY(-{{ block.settings.hover_lift }}px);
    box-shadow: 0 {{ block.settings.hover_lift | times: 2 }}px {{ block.settings.hover_lift | times: 4 }}px rgba(0, 0, 0, 0.15);
  }

  .ai-product-card__image-wrapper-{{ ai_gen_id }} {
    position: relative;
    width: 100%;
    padding-bottom: {{ block.settings.image_aspect_ratio }}%;
    overflow: hidden;
    background-color: #f5f5f5;
  }

  .ai-product-card__image-{{ ai_gen_id }} {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .ai-product-card__image-placeholder-{{ ai_gen_id }} {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    display: flex;
    align-items: center;
    justify-content: center;
    background-color: #f5f5f5;
  }

  .ai-product-card__image-placeholder-{{ ai_gen_id }} svg {
    width: 60%;
    height: 60%;
    opacity: 0.3;
  }

  .ai-product-card__content-{{ ai_gen_id }} {
    padding: {{ block.settings.card_padding }}px;
    flex-grow: 1;
    display: flex;
    flex-direction: column;
  }

  .ai-product-card__title-{{ ai_gen_id }} {
    font-size: {{ block.settings.title_size }}px;
    font-weight: 600;
    color: {{ block.settings.title_color }};
    margin: 0 0 {{ block.settings.card_padding | divided_by: 2 }}px;
    text-decoration: none;
    display: block;
  }

  .ai-product-card__title-{{ ai_gen_id }}:hover {
    color: {{ block.settings.accent_color }};
  }

  .ai-product-card__description-{{ ai_gen_id }} {
    font-size: {{ block.settings.description_size }}px;
    color: {{ block.settings.description_color }};
    line-height: 1.5;
    margin: 0;
  }

  @media screen and (max-width: 749px) {
    .ai-product-carousel__container-{{ ai_gen_id }} {
      width: 100%;
      padding: 0;
    }

    .ai-product-carousel__grid-{{ ai_gen_id }} {
      display: flex;
      overflow-x: auto;
      scroll-snap-type: x mandatory;
      gap: {{ block.settings.mobile_gap }}px;
      padding: 0 20px;
      -webkit-overflow-scrolling: touch;
      scrollbar-width: none;
    }

    .ai-product-carousel__grid-{{ ai_gen_id }}::-webkit-scrollbar {
      display: none;
    }

    .ai-product-card-{{ ai_gen_id }} {
      flex: 0 0 {{ block.settings.mobile_card_width }}%;
      scroll-snap-align: center;
      opacity: {{ block.settings.mobile_side_opacity | divided_by: 100.0 }};
      transform: scale({{ block.settings.mobile_side_scale | divided_by: 100.0 }});
      transition: opacity 0.3s ease, transform 0.3s ease, box-shadow 0.3s ease;
    }

    .ai-product-card-{{ ai_gen_id }}.ai-product-card--center-{{ ai_gen_id }} {
      opacity: 1;
      transform: scale(1);
    }
  }
{% endstyle %}

<product-carousel-{{ ai_gen_id }} class="ai-product-carousel-{{ ai_gen_id }}" {{ block.shopify_attributes }}>
  <div class="ai-product-carousel__container-{{ ai_gen_id }}">
    <div class="ai-product-carousel__grid-{{ ai_gen_id }}">
      {% for i in (1..block.settings.product_count) %}
        {% liquid
          assign product_key = 'product_' | append: i
          assign product = block.settings[product_key]
          assign title_key = 'title_' | append: i
          assign title = block.settings[title_key]
          assign link_key = 'link_' | append: i
          assign link = block.settings[link_key]
          assign description_key = 'description_' | append: i
          assign description = block.settings[description_key]
        %}

        <div class="ai-product-card-{{ ai_gen_id }}" data-card-index="{{ forloop.index0 }}">
          <div class="ai-product-card__image-wrapper-{{ ai_gen_id }}">
            {% if product != blank and product.featured_image %}
              <img
                src="{{ product.featured_image | image_url: width: 800 }}"
                alt="{{ product.featured_image.alt | escape }}"
                class="ai-product-card__image-{{ ai_gen_id }}"
                loading="lazy"
                width="800"
                height="{{ 800 | times: block.settings.image_aspect_ratio | divided_by: 100 }}"
              >
            {% else %}
              <div class="ai-product-card__image-placeholder-{{ ai_gen_id }}">
                {{ 'product-1' | placeholder_svg_tag }}
              </div>
            {% endif %}
          </div>

          <div class="ai-product-card__content-{{ ai_gen_id }}">
            {% if title != blank %}
              {% if link != blank %}
                <a href="{{ link }}" class="ai-product-card__title-{{ ai_gen_id }}">
                  {{ title }}
                </a>
              {% else %}
                <h3 class="ai-product-card__title-{{ ai_gen_id }}">{{ title }}</h3>
              {% endif %}
            {% elsif product != blank %}
              <a href="{{ product.url }}" class="ai-product-card__title-{{ ai_gen_id }}">
                {{ product.title }}
              </a>
            {% endif %}

            {% if description != blank %}
              <div class="ai-product-card__description-{{ ai_gen_id }}">
                {{ description }}
              </div>
            {% elsif product != blank %}
              <div class="ai-product-card__description-{{ ai_gen_id }}">
                {{ product.description | strip_html | truncate: 120 }}
              </div>
            {% endif %}
          </div>
        </div>
      {% endfor %}
    </div>
  </div>
</product-carousel-{{ ai_gen_id }}>

<script>
  (function() {
    class ProductCarousel{{ ai_gen_id }} extends HTMLElement {
      constructor() {
        super();
        this.isMobile = window.innerWidth <= 749;
      }

      connectedCallback() {
        if (this.isMobile) {
          this.setupMobileCarousel();
        }
        
        window.addEventListener('resize', () => {
          const wasMobile = this.isMobile;
          this.isMobile = window.innerWidth <= 749;
          
          if (wasMobile !== this.isMobile) {
            if (this.isMobile) {
              this.setupMobileCarousel();
            } else {
              this.cleanupMobileCarousel();
            }
          }
        });
      }

      setupMobileCarousel() {
        this.grid = this.querySelector('.ai-product-carousel__grid-{{ ai_gen_id }}');
        this.cards = this.querySelectorAll('.ai-product-card-{{ ai_gen_id }}');
        
        if (!this.grid || this.cards.length === 0) return;

        this.updateCenterCard();
        
        this.grid.addEventListener('scroll', () => {
          this.updateCenterCard();
        });

        const middleIndex = Math.floor(this.cards.length / 2);
        const middleCard = this.cards[middleIndex];
        if (middleCard) {
          middleCard.scrollIntoView({ inline: 'center', block: 'nearest', behavior: 'auto' });
        }
      }

      updateCenterCard() {
        if (!this.grid || !this.cards) return;

        const gridRect = this.grid.getBoundingClientRect();
        const gridCenter = gridRect.left + gridRect.width / 2;

        let closestCard = null;
        let closestDistance = Infinity;

        this.cards.forEach((card) => {
          const cardRect = card.getBoundingClientRect();
          const cardCenter = cardRect.left + cardRect.width / 2;
          const distance = Math.abs(cardCenter - gridCenter);

          if (distance < closestDistance) {
            closestDistance = distance;
            closestCard = card;
          }
        });

        this.cards.forEach((card) => {
          card.classList.remove('ai-product-card--center-{{ ai_gen_id }}');
        });

        if (closestCard) {
          closestCard.classList.add('ai-product-card--center-{{ ai_gen_id }}');
        }
      }

      cleanupMobileCarousel() {
        if (this.grid) {
          this.grid.removeEventListener('scroll', this.updateCenterCard);
        }
        if (this.cards) {
          this.cards.forEach((card) => {
            card.classList.remove('ai-product-card--center-{{ ai_gen_id }}');
          });
        }
      }
    }

    customElements.define('product-carousel-{{ ai_gen_id }}', ProductCarousel{{ ai_gen_id }});
  })();
</script>

