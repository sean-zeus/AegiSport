{% doc %}
  @prompt
    logo list, 可以新增以及刪減數量, logo下方可以上文字及設定連結, 置中對齊
{% enddoc %}
{% assign ai_gen_id = block.id | replace: '_', '' | downcase %}

{% style %}
  .ai-logo-list-{{ ai_gen_id }} {
    display: block;
    width: 100%;
    max-width: 100%;
    padding: {{ block.settings.section_padding }}px 0;
    background-color: {{ block.settings.background_color }};
  }

  .ai-logo-list__container-{{ ai_gen_id }} {
    max-width: {{ block.settings.desktop_width_percent }}%;
    margin: 0 auto;
    padding: 0 20px;
  }

  .ai-logo-list__heading-{{ ai_gen_id }} {
    text-align: {{ block.settings.heading_alignment }};
    color: {{ block.settings.heading_color }};
    font-size: {{ block.settings.heading_size }}px;
    margin: 0 0 {{ block.settings.heading_spacing }}px;
  }

  .ai-logo-list__grid-{{ ai_gen_id }} {
    display: grid;
    grid-template-columns: repeat({{ block.settings.logos_per_row }}, 1fr);
    gap: {{ block.settings.grid_gap }}px;
    align-items: center;
    justify-items: center;
  }

  .ai-logo-list__item-{{ ai_gen_id }} {
    display: flex;
    flex-direction: column;
    align-items: center;
    text-align: center;
    padding: {{ block.settings.item_padding }}px;
    background-color: {{ block.settings.item_background_color }};
    border-radius: {{ block.settings.border_radius }}px;
    transition: transform 0.3s ease;
    width: 100%;
  }

  .ai-logo-list__item-{{ ai_gen_id }}:hover {
    transform: translateY(-5px);
  }

  .ai-logo-list__link-{{ ai_gen_id }} {
    display: flex;
    flex-direction: column;
    align-items: center;
    text-decoration: none;
    width: 100%;
  }

  .ai-logo-list__image-wrapper-{{ ai_gen_id }} {
    width: 100%;
    max-width: {{ block.settings.logo_max_width }}px;
    margin: 0 auto {{ block.settings.text_spacing }}px;
  }

  .ai-logo-list__image-{{ ai_gen_id }} {
    width: 100%;
    height: auto;
    display: block;
  }

  .ai-logo-list__placeholder-{{ ai_gen_id }} {
    width: 100%;
    aspect-ratio: 16 / 9;
    background-color: #f4f4f4;
    display: flex;
    align-items: center;
    justify-content: center;
    border-radius: 8px;
  }

  .ai-logo-list__placeholder-{{ ai_gen_id }} svg {
    width: 60%;
    height: 60%;
    opacity: 0.3;
  }

  .ai-logo-list__text-{{ ai_gen_id }} {
    color: {{ block.settings.text_color }};
    font-size: {{ block.settings.text_size }}px;
    margin: 0;
  }

  @media screen and (max-width: 989px) {
    .ai-logo-list__grid-{{ ai_gen_id }} {
      grid-template-columns: repeat({{ block.settings.logos_per_row_tablet }}, 1fr);
    }
  }

  @media screen and (max-width: 749px) {
    .ai-logo-list__grid-{{ ai_gen_id }} {
      grid-template-columns: repeat({{ block.settings.logos_per_row_mobile }}, 1fr);
    }
  }
{% endstyle %}

<logo-list-{{ ai_gen_id }} class="ai-logo-list-{{ ai_gen_id }}" {{ block.shopify_attributes }}>
  <div class="ai-logo-list__container-{{ ai_gen_id }}">
    {% if block.settings.heading != blank %}
      <h2 class="ai-logo-list__heading-{{ ai_gen_id }}">{{ block.settings.heading }}</h2>
    {% endif %}

    <div class="ai-logo-list__grid-{{ ai_gen_id }}">
      {% for i in (1..10) %}
        {% liquid
          assign logo_key = 'logo_' | append: i
          assign text_key = 'logo_text_' | append: i
          assign link_key = 'logo_link_' | append: i
          assign enabled_key = 'logo_' | append: i | append: '_enabled'

          assign logo = block.settings[logo_key]
          assign text = block.settings[text_key]
          assign link = block.settings[link_key]
          assign enabled = block.settings[enabled_key]
        %}

        {% if enabled %}
          <div class="ai-logo-list__item-{{ ai_gen_id }}">
            {% if link != blank %}
              <a href="{{ link }}" class="ai-logo-list__link-{{ ai_gen_id }}">
                <div class="ai-logo-list__image-wrapper-{{ ai_gen_id }}">
                  {% if logo != blank %}
                    <img
                      src="{{ logo | image_url: width: 400 }}"
                      alt="{{ text | escape }}"
                      class="ai-logo-list__image-{{ ai_gen_id }}"
                      loading="lazy"
                      width="{{ logo.width }}"
                      height="{{ logo.height }}"
                    >
                  {% else %}
                    <div class="ai-logo-list__placeholder-{{ ai_gen_id }}">
                      {{ 'image' | placeholder_svg_tag }}
                    </div>
                  {% endif %}
                </div>
                {% if text != blank %}
                  <p class="ai-logo-list__text-{{ ai_gen_id }}">{{ text }}</p>
                {% endif %}
              </a>
            {% else %}
              <div class="ai-logo-list__image-wrapper-{{ ai_gen_id }}">
                {% if logo != blank %}
                  <img
                    src="{{ logo | image_url: width: 400 }}"
                    alt="{{ text | escape }}"
                    class="ai-logo-list__image-{{ ai_gen_id }}"
                    loading="lazy"
                    width="{{ logo.width }}"
                    height="{{ logo.height }}"
                  >
                {% else %}
                  <div class="ai-logo-list__placeholder-{{ ai_gen_id }}">
                    {{ 'image' | placeholder_svg_tag }}
                  </div>
                {% endif %}
              </div>
              {% if text != blank %}
                <p class="ai-logo-list__text-{{ ai_gen_id }}">{{ text }}</p>
              {% endif %}
            {% endif %}
          </div>
        {% endif %}
      {% endfor %}
    </div>
  </div>
</logo-list-{{ ai_gen_id }}>

