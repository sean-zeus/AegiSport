{% doc %}
  @prompt
    圖片與文字編輯器，圖片跟文字可調整對齊方式及調整圖片長寬，, 圖片可以修改比例
{% enddoc %}
{% assign ai_gen_id = block.id | replace: '_', '' | downcase %}

{% style %}
  .ai-image-text-editor-{{ ai_gen_id }} {
    display: block;
    width: {{ block.settings.desktop_width_percent }}%;
    max-width: 100%;
    padding: {{ block.settings.section_padding }}px;
    background-color: {{ block.settings.background_color }};
  }

  .ai-image-text-editor__container-{{ ai_gen_id }} {
    display: flex;
    gap: {{ block.settings.gap }}px;
    align-items: {{ block.settings.vertical_alignment }};
    {% if block.settings.layout == 'image_left' %}
      flex-direction: row;
    {% elsif block.settings.layout == 'image_right' %}
      flex-direction: row-reverse;
    {% elsif block.settings.layout == 'image_top' %}
      flex-direction: column;
    {% else %}
      flex-direction: column-reverse;
    {% endif %}
  }

  .ai-image-text-editor__image-wrapper-{{ ai_gen_id }} {
    {% if block.settings.layout == 'image_left' or block.settings.layout == 'image_right' %}
      flex: 0 0 {{ block.settings.image_width }}%;
    {% else %}
      width: 100%;
    {% endif %}
  }

  .ai-image-text-editor__image-container-{{ ai_gen_id }} {
    width: 100%;
    position: relative;
    overflow: hidden;
    border-radius: {{ block.settings.image_border_radius }}px;
    {% if block.settings.image_aspect_ratio == 'natural' %}
      aspect-ratio: auto;
    {% elsif block.settings.image_aspect_ratio == 'square' %}
      aspect-ratio: 1 / 1;
    {% elsif block.settings.image_aspect_ratio == 'portrait' %}
      aspect-ratio: 3 / 4;
    {% elsif block.settings.image_aspect_ratio == 'landscape' %}
      aspect-ratio: 4 / 3;
    {% elsif block.settings.image_aspect_ratio == 'wide' %}
      aspect-ratio: 16 / 9;
    {% endif %}
  }

  .ai-image-text-editor__image-{{ ai_gen_id }} {
    width: 100%;
    height: 100%;
    display: block;
    {% if block.settings.image_aspect_ratio == 'natural' %}
      object-fit: contain;
    {% else %}
      object-fit: {{ block.settings.image_fit }};
    {% endif %}
  }

  .ai-image-text-editor__image-placeholder-{{ ai_gen_id }} {
    width: 100%;
    height: 100%;
    background-color: #f4f4f4;
    display: flex;
    align-items: center;
    justify-content: center;
    position: relative;
    min-height: 300px;
  }

  .ai-image-text-editor__image-placeholder-{{ ai_gen_id }} svg {
    width: 100%;
    height: 100%;
    max-width: 400px;
    max-height: 400px;
  }

  .ai-image-text-editor__empty-state-{{ ai_gen_id }} {
    position: absolute;
    bottom: 20px;
    left: 50%;
    transform: translateX(-50%);
    padding: 12px 20px;
    font-size: 14px;
    color: #666;
    text-align: center;
    pointer-events: none;
  }

  .ai-image-text-editor__text-wrapper-{{ ai_gen_id }} {
    {% if block.settings.layout == 'image_left' or block.settings.layout == 'image_right' %}
      flex: 1;
    {% else %}
      width: 100%;
    {% endif %}
  }

  .ai-image-text-editor__heading-{{ ai_gen_id }} {
    font-size: {{ block.settings.heading_size }}px;
    color: {{ block.settings.heading_color }};
    margin: 0 0 {{ block.settings.heading_spacing }}px 0;
    text-align: {{ block.settings.text_alignment }};
  }

  .ai-image-text-editor__text-{{ ai_gen_id }} {
    font-size: {{ block.settings.text_size }}px;
    color: {{ block.settings.text_color }};
    line-height: {{ block.settings.line_height }};
    text-align: {{ block.settings.text_alignment }};
    margin: 0;
  }

  @media screen and (max-width: 749px) {
    .ai-image-text-editor__container-{{ ai_gen_id }} {
      {% if block.settings.mobile_layout == 'stack' %}
        flex-direction: column;
      {% endif %}
    }

    .ai-image-text-editor__image-wrapper-{{ ai_gen_id }} {
      {% if block.settings.mobile_layout == 'stack' %}
        flex: none;
        width: 100%;
      {% endif %}
    }

    .ai-image-text-editor__text-wrapper-{{ ai_gen_id }} {
      {% if block.settings.mobile_layout == 'stack' %}
        flex: none;
        width: 100%;
      {% endif %}
    }
  }
{% endstyle %}

<div
  class="ai-image-text-editor-{{ ai_gen_id }}"
  {{ block.shopify_attributes }}
>
  <div class="ai-image-text-editor__container-{{ ai_gen_id }}">
    <div class="ai-image-text-editor__image-wrapper-{{ ai_gen_id }}">
      <div class="ai-image-text-editor__image-container-{{ ai_gen_id }}">
        {% if block.settings.image %}
          <img
            src="{{ block.settings.image | image_url: width: 2000 }}"
            alt="{{ block.settings.image.alt | escape }}"
            loading="lazy"
            width="{{ block.settings.image.width }}"
            height="{{ block.settings.image.height }}"
            class="ai-image-text-editor__image-{{ ai_gen_id }}"
          >
        {% else %}
          <div class="ai-image-text-editor__image-placeholder-{{ ai_gen_id }}">
            {{ 'image' | placeholder_svg_tag }}
            <div class="ai-image-text-editor__empty-state-{{ ai_gen_id }}">
              請新增圖片
            </div>
          </div>
        {% endif %}
      </div>
    </div>

    <div class="ai-image-text-editor__text-wrapper-{{ ai_gen_id }}">
      {% if block.settings.heading != blank %}
        <h2 class="ai-image-text-editor__heading-{{ ai_gen_id }}">
          {{ block.settings.heading }}
        </h2>
      {% endif %}

      {% if block.settings.text != blank %}
        <div class="ai-image-text-editor__text-{{ ai_gen_id }}">
          {{ block.settings.text }}
        </div>
      {% endif %}
    </div>
  </div>
</div>

{% schema %}
{
  "name": "圖片與文字編輯器",
  "settings": [
    {
      "type": "header",
      "content": "版面配置"
    },
    {
      "type": "select",
      "id": "layout",
      "label": "圖片位置",
      "options": [
        {
          "value": "image_left",
          "label": "圖片在左"
        },
        {
          "value": "image_right",
          "label": "圖片在右"
        },
        {
          "value": "image_top",
          "label": "圖片在上"
        },
        {
          "value": "image_bottom",
          "label": "圖片在下"
        }
      ],
      "default": "image_left"
    },
    {
      "type": "select",
      "id": "mobile_layout",
      "label": "手機版配置",
      "options": [
        {
          "value": "stack",
          "label": "堆疊顯示"
        },
        {
          "value": "keep",
          "label": "保持桌面版配置"
        }
      ],
      "default": "stack"
    },
    {
      "type": "range",
      "id": "desktop_width_percent",
      "label": "桌面版寬度",
      "min": 50,
      "max": 100,
      "step": 5,
      "unit": "%",
      "default": 100
    },
    {
      "type": "range",
      "id": "section_padding",
      "label": "區塊內距",
      "min": 0,
      "max": 100,
      "step": 5,
      "unit": "px",
      "default": 40
    },
    {
      "type": "range",
      "id": "gap",
      "label": "圖片與文字間距",
      "min": 0,
      "max": 100,
      "step": 5,
      "unit": "px",
      "default": 40
    },
    {
      "type": "select",
      "id": "vertical_alignment",
      "label": "垂直對齊",
      "options": [
        {
          "value": "flex-start",
          "label": "頂部對齊"
        },
        {
          "value": "center",
          "label": "置中對齊"
        },
        {
          "value": "flex-end",
          "label": "底部對齊"
        }
      ],
      "default": "center"
    },
    {
      "type": "color",
      "id": "background_color",
      "label": "背景顏色",
      "default": "#ffffff"
    },
    {
      "type": "header",
      "content": "圖片設定"
    },
    {
      "type": "image_picker",
      "id": "image",
      "label": "圖片"
    },
    {
      "type": "range",
      "id": "image_width",
      "label": "圖片寬度（左右配置時）",
      "min": 20,
      "max": 80,
      "step": 5,
      "unit": "%",
      "default": 50
    },
    {
      "type": "select",
      "id": "image_aspect_ratio",
      "label": "圖片比例",
      "options": [
        {
          "value": "natural",
          "label": "原始比例"
        },
        {
          "value": "square",
          "label": "正方形 (1:1)"
        },
        {
          "value": "portrait",
          "label": "直式 (3:4)"
        },
        {
          "value": "landscape",
          "label": "橫式 (4:3)"
        },
        {
          "value": "wide",
          "label": "寬螢幕 (16:9)"
        }
      ],
      "default": "natural"
    },
    {
      "type": "select",
      "id": "image_fit",
      "label": "圖片填滿方式",
      "info": "僅在選擇非原始比例時生效",
      "options": [
        {
          "value": "cover",
          "label": "覆蓋（裁切）"
        },
        {
          "value": "contain",
          "label": "包含（完整顯示）"
        }
      ],
      "default": "cover"
    },
    {
      "type": "range",
      "id": "image_border_radius",
      "label": "圖片圓角",
      "min": 0,
      "max": 40,
      "step": 2,
      "unit": "px",
      "default": 0
    },
    {
      "type": "header",
      "content": "文字內容"
    },
    {
      "type": "inline_richtext",
      "id": "heading",
      "label": "標題",
      "default": "圖片與文字"
    },
    {
      "type": "richtext",
      "id": "text",
      "label": "內文",
      "default": "<p>在此新增您的內容描述。您可以調整圖片位置、大小以及文字對齊方式。</p>"
    },
    {
      "type": "header",
      "content": "文字樣式"
    },
    {
      "type": "select",
      "id": "text_alignment",
      "label": "文字對齊",
      "options": [
        {
          "value": "left",
          "label": "靠左對齊"
        },
        {
          "value": "center",
          "label": "置中對齊"
        },
        {
          "value": "right",
          "label": "靠右對齊"
        }
      ],
      "default": "left"
    },
    {
      "type": "range",
      "id": "heading_size",
      "label": "標題大小",
      "min": 16,
      "max": 60,
      "step": 2,
      "unit": "px",
      "default": 32
    },
    {
      "type": "range",
      "id": "heading_spacing",
      "label": "標題下方間距",
      "min": 0,
      "max": 50,
      "step": 5,
      "unit": "px",
      "default": 20
    },
    {
      "type": "color",
      "id": "heading_color",
      "label": "標題顏色",
      "default": "#222021"
    },
    {
      "type": "range",
      "id": "text_size",
      "label": "內文大小",
      "min": 12,
      "max": 30,
      "step": 1,
      "unit": "px",
      "default": 16
    },
    {
      "type": "range",
      "id": "line_height",
      "label": "行高",
      "min": 1,
      "max": 2,
      "step": 0.1,
      "default": 1.6
    },
    {
      "type": "color",
      "id": "text_color",
      "label": "內文顏色",
      "default": "#616161"
    }
  ],
  "presets": [
    {
      "name": "圖片與文字編輯器"
    }
  ]
}
{% endschema %}