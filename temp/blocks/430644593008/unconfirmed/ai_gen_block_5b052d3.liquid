{% doc %}
  @prompt
    三個logo list, 置中對齊, 可以更換圖片, 個別的logo大標題、內容, 手機版要改變成左右滾動, 高度統一
{% enddoc %}
{% assign ai_gen_id = block.id | replace: '_', '' | downcase %}

{% style %}
  .ai-logo-list-{{ ai_gen_id }} {
    display: block;
    width: {{ block.settings.desktop_width_percent }}%;
    max-width: 100%;
    padding: {{ block.settings.section_padding }}px 0;
  }

  .ai-logo-list__container-{{ ai_gen_id }} {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: {{ block.settings.gap }}px;
    max-width: {{ block.settings.max_width }}px;
    margin: 0 auto;
  }

  .ai-logo-list__item-{{ ai_gen_id }} {
    display: flex;
    flex-direction: column;
    align-items: center;
    text-align: center;
    gap: {{ block.settings.item_gap }}px;
  }

  .ai-logo-list__image-wrapper-{{ ai_gen_id }} {
    width: 100%;
    max-width: {{ block.settings.logo_max_width }}px;
    height: {{ block.settings.logo_height }}px;
    margin: 0 auto;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .ai-logo-list__image-{{ ai_gen_id }} {
    width: 100%;
    height: 100%;
    object-fit: contain;
    display: block;
  }

  .ai-logo-list__placeholder-{{ ai_gen_id }} {
    width: 100%;
    height: 100%;
    background-color: {{ block.settings.placeholder_bg_color }};
    display: flex;
    align-items: center;
    justify-content: center;
    border-radius: {{ block.settings.border_radius }}px;
  }

  .ai-logo-list__placeholder-{{ ai_gen_id }} svg {
    width: 60%;
    height: 60%;
    opacity: 0.3;
  }

  .ai-logo-list__content-{{ ai_gen_id }} {
    width: 100%;
  }

  .ai-logo-list__title-{{ ai_gen_id }} {
    font-size: {{ block.settings.title_size }}px;
    font-weight: {{ block.settings.title_weight }};
    color: {{ block.settings.title_color }};
    margin: 0 0 {{ block.settings.title_margin }}px 0;
  }

  .ai-logo-list__text-{{ ai_gen_id }} {
    font-size: {{ block.settings.text_size }}px;
    color: {{ block.settings.text_color }};
    line-height: 1.6;
    margin: 0;
  }

  @media screen and (max-width: 749px) {
    .ai-logo-list-{{ ai_gen_id }} {
      overflow: hidden;
    }

    .ai-logo-list__container-{{ ai_gen_id }} {
      display: flex;
      overflow-x: auto;
      scroll-snap-type: x mandatory;
      gap: {{ block.settings.mobile_gap }}px;
      padding: 0 20px;
      margin: 0;
      max-width: 100%;
      -webkit-overflow-scrolling: touch;
      scrollbar-width: none;
    }

    .ai-logo-list__container-{{ ai_gen_id }}::-webkit-scrollbar {
      display: none;
    }

    .ai-logo-list__item-{{ ai_gen_id }} {
      flex: 0 0 {{ block.settings.mobile_item_width }}%;
      scroll-snap-align: start;
      min-width: {{ block.settings.mobile_item_width }}%;
    }

    .ai-logo-list__title-{{ ai_gen_id }} {
      font-size: {{ block.settings.title_size | times: 0.9 }}px;
    }

    .ai-logo-list__text-{{ ai_gen_id }} {
      font-size: {{ block.settings.text_size | times: 0.9 }}px;
    }
  }
{% endstyle %}

<logo-list-{{ ai_gen_id }} class="ai-logo-list-{{ ai_gen_id }}" {{ block.shopify_attributes }}>
  <div class="ai-logo-list__container-{{ ai_gen_id }}">
    {% for i in (1..3) %}
      {% liquid
        assign image_key = 'logo_' | append: i
        assign title_key = 'title_' | append: i
        assign text_key = 'text_' | append: i
        
        assign logo_image = block.settings[image_key]
        assign logo_title = block.settings[title_key]
        assign logo_text = block.settings[text_key]
      %}
      
      <div class="ai-logo-list__item-{{ ai_gen_id }}">
        <div class="ai-logo-list__image-wrapper-{{ ai_gen_id }}">
          {% if logo_image %}
            <img
              src="{{ logo_image | image_url: width: 600 }}"
              alt="{{ logo_title | escape }}"
              class="ai-logo-list__image-{{ ai_gen_id }}"
              loading="lazy"
              width="{{ logo_image.width }}"
              height="{{ logo_image.height }}"
            >
          {% else %}
            <div class="ai-logo-list__placeholder-{{ ai_gen_id }}">
              {{ 'image' | placeholder_svg_tag }}
            </div>
          {% endif %}
        </div>
        
        <div class="ai-logo-list__content-{{ ai_gen_id }}">
          {% if logo_title != blank %}
            <h3 class="ai-logo-list__title-{{ ai_gen_id }}">{{ logo_title }}</h3>
          {% endif %}
          
          {% if logo_text != blank %}
            <div class="ai-logo-list__text-{{ ai_gen_id }}">{{ logo_text }}</div>
          {% endif %}
        </div>
      </div>
    {% endfor %}
  </div>
</logo-list-{{ ai_gen_id }}>

<script>
  (function() {
    class LogoList{{ ai_gen_id }} extends HTMLElement {
      constructor() {
        super();
      }

      connectedCallback() {
      }
    }

    customElements.define('logo-list-{{ ai_gen_id }}', LogoList{{ ai_gen_id }});
  })();
</script>

{% schema %}
