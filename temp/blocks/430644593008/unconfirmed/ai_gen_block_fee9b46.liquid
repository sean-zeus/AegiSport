{% doc %}
  @prompt
    一張圖片，響應式，手機版要4:5尺寸，, 置中對齊, 可以更換圖片, 左右滿版，個別的logo大標題、內容, 手機版要改變成左右滾動, 高度統一
{% enddoc %}
{% assign ai_gen_id = block.id | replace: '_', '' | downcase %}

{% style %}
  .ai-responsive-image-container-{{ ai_gen_id }} {
    display: block;
    width: 100%;
    padding: 0;
    margin: 0;
  }

  .ai-responsive-image-wrapper-{{ ai_gen_id }} {
    width: 100%;
    max-width: 100%;
    margin: 0 auto;
    position: relative;
  }

  .ai-responsive-image-{{ ai_gen_id }} {
    width: 100%;
    height: auto;
    display: block;
    object-fit: cover;
  }

  .ai-responsive-image-placeholder-{{ ai_gen_id }} {
    width: 100%;
    background-color: #f4f4f4;
    display: flex;
    align-items: center;
    justify-content: center;
    position: relative;
  }

  .ai-responsive-image-placeholder-{{ ai_gen_id }} svg {
    width: 100%;
    height: 100%;
  }

  .ai-responsive-image-empty-state-{{ ai_gen_id }} {
    position: absolute;
    bottom: 20px;
    left: 50%;
    transform: translateX(-50%);
    padding: 12px 20px;
    font-size: 14px;
    color: #666;
    text-align: center;
    pointer-events: none;
  }

  .ai-responsive-image-content-{{ ai_gen_id }} {
    margin-top: {{ block.settings.content_spacing }}px;
  }

  .ai-responsive-image-logo-{{ ai_gen_id }} {
    width: {{ block.settings.logo_width }}px;
    height: auto;
    display: block;
    margin: 0 auto {{ block.settings.logo_spacing }}px;
  }

  .ai-responsive-image-logo-placeholder-{{ ai_gen_id }} {
    width: {{ block.settings.logo_width }}px;
    height: 60px;
    background-color: #f4f4f4;
    display: flex;
    align-items: center;
    justify-content: center;
    margin: 0 auto {{ block.settings.logo_spacing }}px;
  }

  .ai-responsive-image-logo-placeholder-{{ ai_gen_id }} svg {
    width: 100%;
    height: 100%;
  }

  .ai-responsive-image-title-{{ ai_gen_id }} {
    font-size: {{ block.settings.title_size }}px;
    color: {{ block.settings.title_color }};
    text-align: center;
    margin: 0 0 {{ block.settings.title_spacing }}px;
    font-weight: 600;
  }

  .ai-responsive-image-text-{{ ai_gen_id }} {
    font-size: {{ block.settings.text_size }}px;
    color: {{ block.settings.text_color }};
    text-align: center;
    line-height: 1.6;
    margin: 0;
  }

  @media screen and (max-width: 749px) {
    .ai-responsive-image-wrapper-{{ ai_gen_id }} {
      aspect-ratio: 4 / 5;
      overflow: hidden;
    }

    .ai-responsive-image-{{ ai_gen_id }} {
      width: 100%;
      height: 100%;
      object-fit: cover;
    }

    .ai-responsive-image-placeholder-{{ ai_gen_id }} {
      aspect-ratio: 4 / 5;
    }

    .ai-responsive-image-content-{{ ai_gen_id }} {
      display: flex;
      overflow-x: auto;
      scroll-snap-type: x mandatory;
      gap: 20px;
      padding: 0 20px;
      -webkit-overflow-scrolling: touch;
      scrollbar-width: none;
    }

    .ai-responsive-image-content-{{ ai_gen_id }}::-webkit-scrollbar {
      display: none;
    }

    .ai-responsive-image-item-{{ ai_gen_id }} {
      flex: 0 0 80%;
      scroll-snap-align: center;
    }

    .ai-responsive-image-logo-{{ ai_gen_id }},
    .ai-responsive-image-logo-placeholder-{{ ai_gen_id }} {
      margin-left: 0;
      margin-right: 0;
    }

    .ai-responsive-image-title-{{ ai_gen_id }},
    .ai-responsive-image-text-{{ ai_gen_id }} {
      text-align: left;
    }
  }

  @media screen and (min-width: 750px) {
    .ai-responsive-image-content-{{ ai_gen_id }} {
      display: flex;
      justify-content: center;
      align-items: flex-start;
      gap: {{ block.settings.desktop_gap }}px;
      max-width: {{ block.settings.desktop_width_percent }}%;
      margin-left: auto;
      margin-right: auto;
    }

    .ai-responsive-image-item-{{ ai_gen_id }} {
      flex: 1;
      min-width: 0;
    }
  }
{% endstyle %}

<responsive-image-{{ ai_gen_id }}
  class="ai-responsive-image-container-{{ ai_gen_id }}"
  {{ block.shopify_attributes }}
>
  <div class="ai-responsive-image-wrapper-{{ ai_gen_id }}">
    {% if block.settings.image %}
      <img
        src="{{ block.settings.image | image_url: width: 2000 }}"
        alt="{{ block.settings.image.alt | escape }}"
        loading="lazy"
        width="{{ block.settings.image.width }}"
        height="{{ block.settings.image.height }}"
        class="ai-responsive-image-{{ ai_gen_id }}"
      >
    {% else %}
      <div class="ai-responsive-image-placeholder-{{ ai_gen_id }}">
        {{ 'image' | placeholder_svg_tag }}
        <div class="ai-responsive-image-empty-state-{{ ai_gen_id }}">
          請新增圖片
        </div>
      </div>
    {% endif %}
  </div>

  <div class="ai-responsive-image-content-{{ ai_gen_id }}">
    {% for i in (1..3) %}
      {% liquid
        assign logo_key = 'logo_' | append: i
        assign title_key = 'title_' | append: i
        assign text_key = 'text_' | append: i
        
        assign logo = block.settings[logo_key]
        assign title = block.settings[title_key]
        assign text = block.settings[text_key]
      %}
      
      <div class="ai-responsive-image-item-{{ ai_gen_id }}">
        {% if logo %}
          <img
            src="{{ logo | image_url: width: 400 }}"
            alt="{{ logo.alt | escape }}"
            loading="lazy"
            class="ai-responsive-image-logo-{{ ai_gen_id }}"
          >
        {% else %}
          <div class="ai-responsive-image-logo-placeholder-{{ ai_gen_id }}">
            {{ 'image' | placeholder_svg_tag }}
          </div>
        {% endif %}

        {% if title != blank %}
          <h3 class="ai-responsive-image-title-{{ ai_gen_id }}">{{ title }}</h3>
        {% endif %}

        {% if text != blank %}
          <div class="ai-responsive-image-text-{{ ai_gen_id }}">{{ text }}</div>
        {% endif %}
      </div>
    {% endfor %}
  </div>
</responsive-image-{{ ai_gen_id }}>

<script>
  (function() {
    class ResponsiveImage{{ ai_gen_id }} extends HTMLElement {
      constructor() {
        super();
      }

      connectedCallback() {
        this.setupMobileScroll();
      }

      setupMobileScroll() {
        const content = this.querySelector('.ai-responsive-image-content-{{ ai_gen_id }}');
        if (!content) return;

        let isDown = false;
        let startX;
        let scrollLeft;

        content.addEventListener('mousedown', (e) => {
          if (window.innerWidth > 749) return;
          isDown = true;
          startX = e.pageX - content.offsetLeft;
          scrollLeft = content.scrollLeft;
        });

        content.addEventListener('mouseleave', () => {
          isDown = false;
        });

        content.addEventListener('mouseup', () => {
          isDown = false;
        });

        content.addEventListener('mousemove', (e) => {
          if (!isDown) return;
          if (window.innerWidth > 749) return;
          e.preventDefault();
          const x = e.pageX - content.offsetLeft;
          const walk = (x - startX) * 2;
          content.scrollLeft = scrollLeft - walk;
        });
      }
    }

    customElements.define('responsive-image-{{ ai_gen_id }}', ResponsiveImage{{ ai_gen_id }});
  })();
</script>

