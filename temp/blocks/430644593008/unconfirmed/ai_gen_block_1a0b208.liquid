{% doc %}
  @prompt
    一個logo list, 置中對齊, 可以更換圖片, 左右滿版，個別的logo大標題、內容, 手機版要改變成左右滾動, 高度統一
{% enddoc %}
{% assign ai_gen_id = block.id | replace: '_', '' | downcase %}

{% style %}
  .ai-logo-list-{{ ai_gen_id }} {
    display: block;
    width: 100%;
    background-color: {{ block.settings.background_color }};
    padding: {{ block.settings.section_padding }}px 0;
  }

  .ai-logo-list-container-{{ ai_gen_id }} {
    width: 100%;
    max-width: 100%;
    margin: 0 auto;
  }

  .ai-logo-list-grid-{{ ai_gen_id }} {
    display: grid;
    grid-template-columns: repeat({{ block.settings.logos_per_row }}, 1fr);
    gap: {{ block.settings.gap }}px;
    padding: 0 {{ block.settings.horizontal_padding }}px;
  }

  .ai-logo-list-item-{{ ai_gen_id }} {
    display: flex;
    flex-direction: column;
    align-items: center;
    text-align: center;
    height: {{ block.settings.logo_height }}px;
    justify-content: center;
    padding: {{ block.settings.item_padding }}px;
    background-color: {{ block.settings.item_background_color }};
    border-radius: {{ block.settings.border_radius }}px;
  }

  .ai-logo-list-image-wrapper-{{ ai_gen_id }} {
    width: 100%;
    height: 100%;
    display: flex;
    align-items: center;
    justify-content: center;
    margin-bottom: 12px;
  }

  .ai-logo-list-image-{{ ai_gen_id }} {
    max-width: 100%;
    max-height: 100%;
    width: auto;
    height: auto;
    object-fit: contain;
  }

  .ai-logo-list-placeholder-{{ ai_gen_id }} {
    width: 100%;
    height: 100%;
    display: flex;
    align-items: center;
    justify-content: center;
    background-color: #f4f4f4;
    border-radius: 4px;
  }

  .ai-logo-list-placeholder-{{ ai_gen_id }} svg {
    width: 60%;
    height: 60%;
    opacity: 0.3;
  }

  .ai-logo-list-title-{{ ai_gen_id }} {
    font-size: {{ block.settings.title_size }}px;
    font-weight: 600;
    color: {{ block.settings.title_color }};
    margin: 0 0 8px 0;
  }

  .ai-logo-list-content-{{ ai_gen_id }} {
    font-size: {{ block.settings.content_size }}px;
    color: {{ block.settings.content_color }};
    margin: 0;
    line-height: 1.5;
  }

  @media screen and (max-width: 749px) {
    .ai-logo-list-grid-{{ ai_gen_id }} {
      display: flex;
      overflow-x: auto;
      scroll-snap-type: x mandatory;
      -webkit-overflow-scrolling: touch;
      gap: {{ block.settings.gap }}px;
      padding: 0 {{ block.settings.horizontal_padding }}px;
    }

    .ai-logo-list-item-{{ ai_gen_id }} {
      flex: 0 0 {{ block.settings.mobile_item_width }}%;
      scroll-snap-align: start;
      height: {{ block.settings.logo_height }}px;
    }

    .ai-logo-list-grid-{{ ai_gen_id }}::-webkit-scrollbar {
      display: none;
    }

    .ai-logo-list-grid-{{ ai_gen_id }} {
      -ms-overflow-style: none;
      scrollbar-width: none;
    }
  }
{% endstyle %}

<logo-list-{{ ai_gen_id }} class="ai-logo-list-{{ ai_gen_id }}" {{ block.shopify_attributes }}>
  <div class="ai-logo-list-container-{{ ai_gen_id }}">
    <div class="ai-logo-list-grid-{{ ai_gen_id }}">
      {% for i in (1..6) %}
        {% liquid
          assign logo_key = 'logo_' | append: i
          assign title_key = 'title_' | append: i
          assign content_key = 'content_' | append: i
          
          assign logo = block.settings[logo_key]
          assign title = block.settings[title_key]
          assign content = block.settings[content_key]
        %}
        
        <div class="ai-logo-list-item-{{ ai_gen_id }}">
          <div class="ai-logo-list-image-wrapper-{{ ai_gen_id }}">
            {% if logo %}
              <img
                src="{{ logo | image_url: width: 400 }}"
                alt="{{ title | escape }}"
                class="ai-logo-list-image-{{ ai_gen_id }}"
                loading="lazy"
                width="{{ logo.width }}"
                height="{{ logo.height }}"
              >
            {% else %}
              <div class="ai-logo-list-placeholder-{{ ai_gen_id }}">
                {{ 'image' | placeholder_svg_tag }}
              </div>
            {% endif %}
          </div>
          
          {% if title != blank %}
            <h3 class="ai-logo-list-title-{{ ai_gen_id }}">{{ title }}</h3>
          {% endif %}
          
          {% if content != blank %}
            <p class="ai-logo-list-content-{{ ai_gen_id }}">{{ content }}</p>
          {% endif %}
        </div>
      {% endfor %}
    </div>
  </div>
</logo-list-{{ ai_gen_id }}>

<script>
  (function() {
    class LogoList{{ ai_gen_id }} extends HTMLElement {
      constructor() {
        super();
      }

      connectedCallback() {
        this.setupMobileScroll();
      }

      setupMobileScroll() {
        const grid = this.querySelector('.ai-logo-list-grid-{{ ai_gen_id }}');
        if (!grid) return;

        let isDown = false;
        let startX;
        let scrollLeft;

        grid.addEventListener('mousedown', (e) => {
          if (window.innerWidth > 749) return;
          isDown = true;
          startX = e.pageX - grid.offsetLeft;
          scrollLeft = grid.scrollLeft;
        });

        grid.addEventListener('mouseleave', () => {
          isDown = false;
        });

        grid.addEventListener('mouseup', () => {
          isDown = false;
        });

        grid.addEventListener('mousemove', (e) => {
          if (!isDown) return;
          if (window.innerWidth > 749) return;
          e.preventDefault();
          const x = e.pageX - grid.offsetLeft;
          const walk = (x - startX) * 2;
          grid.scrollLeft = scrollLeft - walk;
        });
      }
    }

    customElements.define('logo-list-{{ ai_gen_id }}', LogoList{{ ai_gen_id }});
  })();
</script>

